@model IEnumerable<EtapaAifa>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.DetalleEtapa.TipoEtapa)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Direccion.NombreDir)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Estudiante.NombreCompleto)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Subdireccion.NombreSub)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaInicio)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaFin)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Activa)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.DetalleEtapa.TipoEtapa)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Direccion.NombreDir)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Estudiante.NombreCompleto)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Subdireccion.NombreSub)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaInicio)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaFin)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Activa)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Id }) |
            @Html.ActionLink("Details", "Details", new { id=item.Id }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Id })
        </td>
    </tr>
}

</table>
