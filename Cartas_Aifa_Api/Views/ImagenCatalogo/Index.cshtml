@model IEnumerable<Cartas_Aifa_Api.Models.ImagenCatalogo>

@{
    ViewBag.Title = "Catálogo de Logos";
}

<h2>Catálogo de Imágenes</h2>

<p>
    @Html.ActionLink("Subir Nueva Imagen", "Create", null, new { @class = "btn btn-success" })
</p>

<table class="table table-striped">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.NombreArchivo)
        </th>
        @* Cambiamos el encabezado para que sea más claro *@
        <th>
            Vista Previa
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaCarga)
        </th>
        <th>Acciones</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NombreArchivo)
            </td>
            <td>
                @* USAMOS Url.Content para convertir la ruta guardada (/Uploads/...)
                    en una ruta que el navegador entienda correctamente.
                *@
                @if (!string.IsNullOrEmpty(item.UrlImagen))
                {
                    <img src="@Url.Content(item.UrlImagen)"
                         alt="@item.NombreArchivo"
                         style="width: 100px; height: auto; border: 1px solid #ddd; padding: 5px; border-radius: 5px;" />
                }
                else
                {
                    <span class="text-muted">Sin imagen</span>
                }
            </td>
            <td>
                @* Formateamos la fecha para que se vea más limpia *@
                @item.FechaCarga.ToString("dd/MM/yyyy HH:mm")
            </td>
            <td>
                @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-info" }) |
                @Html.ActionLink("Eliminar", "Delete", new { id = item.Id }, new { @class = "btn btn-sm btn-danger" })
            </td>
        </tr>
    }

</table>