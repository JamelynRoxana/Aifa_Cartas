@model IEnumerable<Cartas_Aifa_Api.Models.ConfiguracionVisual>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Imagen.NombreArchivo)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.CoordX)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.CoordY)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Ancho)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Alto)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.AnioAplicacion)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.MostrarEn)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaInicio)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaFin)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Imagen.NombreArchivo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CoordX)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CoordY)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Ancho)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Alto)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.AnioAplicacion)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.MostrarEn)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaInicio)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaFin)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Id }) |
            @Html.ActionLink("Details", "Details", new { id=item.Id }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Id })
        </td>
    </tr>
}

</table>
