@model Cartas_Aifa_Api.Models.ConfiguracionVisual
@{ ViewBag.Title = "Configuración Visual — AIFA"; }

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">

<style>
    :root {
        --aifa-navy: #0a1628;
        --aifa-blue: #1a3a6e;
        --aifa-sky: #1e6fb5;
        --aifa-glow: #5bc4f5;
        --aifa-gold: #c9a84c;
        --aifa-red: #d4273a;
        --aifa-teal: #1da89e;
        --paper: #f4f6f9;
    }

    /* ── Página ── */
    body {
        background: var(--paper);
        font-family: 'Rajdhani', sans-serif;
    }

    /* ── Header ── */
    .aifa-header {
        background: linear-gradient(135deg, var(--aifa-navy) 0%, var(--aifa-blue) 60%, var(--aifa-sky) 100%);
        padding: 18px 28px 14px;
        display: flex;
        align-items: center;
        gap: 18px;
        border-bottom: 2px solid var(--aifa-gold);
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

        .aifa-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient( 90deg, transparent, transparent 60px, rgba(255,255,255,0.025) 60px, rgba(255,255,255,0.026) 61px );
            pointer-events: none;
        }

    .aifa-header-text {
        flex: 1;
    }

    .aifa-header-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 3px;
        text-transform: uppercase;
        line-height: 1;
    }

    .aifa-header-sub {
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        color: var(--aifa-glow);
        letter-spacing: 3px;
        margin-top: 3px;
        text-transform: uppercase;
    }

    .aifa-badge {
        background: rgba(201,168,76,0.15);
        border: 1px solid var(--aifa-gold);
        color: var(--aifa-gold);
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        padding: 5px 12px;
        letter-spacing: 2px;
        border-radius: 3px;
        white-space: nowrap;
    }

    /* ── Lienzo ── */
    .lienzo-label {
        font-family: 'Share Tech Mono', monospace;
        font-size: 10px;
        letter-spacing: 3px;
        color: var(--aifa-sky);
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }

        .lienzo-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, var(--aifa-sky), transparent);
        }

    #contenedor-hoja {
        width: 100%;
        max-width: 500px;
        height: 700px;
        background: white;
        border: 1px solid rgba(91,196,245,0.35);
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 0 1px rgba(91,196,245,0.1), 0 10px 40px rgba(10,22,40,0.18);
        border-radius: 4px;
        margin: auto;
    }

    /* Marcas de esquina */
    .sheet-corner {
        position: absolute;
        width: 14px;
        height: 14px;
        border-color: rgba(91,196,245,0.4);
        border-style: solid;
        border-width: 0;
        z-index: 1;
    }

        .sheet-corner.tl {
            top: 6px;
            left: 6px;
            border-top-width: 1.5px;
            border-left-width: 1.5px;
        }

        .sheet-corner.tr {
            top: 6px;
            right: 6px;
            border-top-width: 1.5px;
            border-right-width: 1.5px;
        }

        .sheet-corner.bl {
            bottom: 6px;
            left: 6px;
            border-bottom-width: 1.5px;
            border-left-width: 1.5px;
        }

        .sheet-corner.br {
            bottom: 6px;
            right: 6px;
            border-bottom-width: 1.5px;
            border-right-width: 1.5px;
        }

    /* Watermark */
    .watermark-area {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 0;
        gap: 8px;
    }

    .watermark-svg {
        opacity: 0.07;
    }

    .watermark-text {
        font-family: 'Rajdhani', sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 4px;
        color: rgba(30,111,181,0.5);
        text-transform: uppercase;
    }

    /* Stripes de pista */
    .runway-stripe {
        position: absolute;
        bottom: 10%;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        gap: 8px;
        pointer-events: none;
        z-index: 0;
        opacity: 0.05;
    }

        .runway-stripe span {
            display: block;
            width: 20px;
            height: 40px;
            background: var(--aifa-sky);
        }

    /* ── Elementos en lienzo ── */
    .elem-lienzo {
        position: absolute;
        cursor: move;
        background-size: 100% 100%;
        background-repeat: no-repeat;
        box-sizing: border-box;
    }

        .elem-lienzo .lbl {
            font-family: 'Share Tech Mono', monospace;
            font-size: 9px;
            padding: 2px 6px;
            position: absolute;
            top: 0;
            left: 0;
            pointer-events: none;
            white-space: nowrap;
            letter-spacing: 0.5px;
        }

        .elem-lienzo.es-nuevo {
            border: 1.5px dashed var(--aifa-red);
            z-index: 20;
        }

            .elem-lienzo.es-nuevo .lbl {
                background: rgba(212,39,58,0.85);
                color: #fff;
            }

        .elem-lienzo.es-existente {
            border: 1.5px dashed var(--aifa-gold);
            z-index: 10;
            opacity: .85;
        }

            .elem-lienzo.es-existente .lbl {
                background: rgba(201,168,76,0.9);
                color: #1a1a1a;
            }

        .elem-lienzo.seleccionado {
            box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--aifa-glow);
            z-index: 30 !important;
            opacity: 1 !important;
        }

    /* ── Leyenda ── */
    .leyenda {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin-top: 10px;
        font-family: 'Share Tech Mono', monospace;
        font-size: 10px;
        color: #888;
        letter-spacing: 1px;
    }

        .leyenda span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .dot {
        width: 14px;
        height: 10px;
        display: inline-block;
    }

    .dot-rojo {
        border: 1.5px dashed var(--aifa-red);
    }

    .dot-gold {
        border: 1.5px dashed var(--aifa-gold);
    }

    /* ── Panel ── */
    .panel-config {
        background: var(--aifa-navy);
        color: #e8eaf0;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(10,22,40,0.25);
    }

    .panel-section {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

        .panel-section:last-child {
            border-bottom: none;
        }

    .panel-section-title {
        font-family: 'Share Tech Mono', monospace;
        font-size: 10px;
        letter-spacing: 2.5px;
        color: var(--aifa-glow);
        text-transform: uppercase;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .panel-section-title::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--aifa-glow);
            flex-shrink: 0;
        }

        .panel-section-title.gold-dot::before {
            background: var(--aifa-gold);
        }

        .panel-section-title.red-dot::before {
            background: var(--aifa-red);
        }

    label.flabel {
        font-family: 'Share Tech Mono', monospace;
        font-size: 9px;
        letter-spacing: 1.5px;
        color: #7a8aaa;
        text-transform: uppercase;
        display: block;
        margin-bottom: 4px;
    }

    .panel-config .form-control {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        color: #e8eaf0;
        border-radius: 3px;
        font-family: 'Share Tech Mono', monospace;
        font-size: 12px;
        padding: 6px 10px;
        width: 100%;
        transition: border-color 0.15s;
    }

        .panel-config .form-control:focus {
            outline: none;
            border-color: var(--aifa-glow);
            background: rgba(91,196,245,0.06);
        }

    .fgroup {
        margin-bottom: 10px;
    }

        .fgroup:last-child {
            margin-bottom: 0;
        }

    .frow {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    /* ── Aviso existentes ── */
    #aviso-existentes {
        display: none;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.35);
        color: var(--aifa-gold);
        padding: 7px 10px;
        font-family: 'Share Tech Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.5px;
        border-radius: 3px;
        margin-top: 8px;
    }

    /* ── Lista elementos ── */
    #lista-elementos {
        max-height: 180px;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(91,196,245,0.3) transparent;
    }

    .item-lista {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        cursor: pointer;
        transition: background 0.1s;
        font-size: 12px;
    }

        .item-lista:last-child {
            border-bottom: none;
        }

        .item-lista:hover {
            background: rgba(255,255,255,0.04);
        }

        .item-lista.activo {
            background: rgba(91,196,245,0.08);
            border-left: 2px solid var(--aifa-glow);
            padding-left: 8px;
        }

        .item-lista.es-nuevo.activo {
            border-left-color: var(--aifa-red);
        }

        .item-lista.es-existente.activo {
            border-left-color: var(--aifa-gold);
        }

    .item-thumb {
        width: 30px;
        height: 22px;
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,0.12);
        flex-shrink: 0;
        border-radius: 2px;
    }

    .item-nombre {
        flex: 1;
        color: #b0bcd0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-family: 'Share Tech Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.5px;
    }

    .tag-tipo {
        font-family: 'Share Tech Mono', monospace;
        font-size: 9px;
        padding: 2px 5px;
        border-radius: 2px;
        letter-spacing: 1px;
        flex-shrink: 0;
    }

    .tag-nuevo {
        background: rgba(212,39,58,0.2);
        color: #f07080;
        border: 1px solid rgba(212,39,58,0.4);
    }

    .tag-exist {
        background: rgba(201,168,76,0.2);
        color: var(--aifa-gold);
        border: 1px solid rgba(201,168,76,0.4);
    }

    /* ── Panel edición ── */
    #panel-edicion {
        display: none;
    }

    /* ── Botones ── */
    .btn-agregar {
        width: 100%;
        padding: 9px;
        background: transparent;
        border: 1px solid var(--aifa-sky);
        color: var(--aifa-glow);
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        letter-spacing: 2px;
        cursor: pointer;
        border-radius: 3px;
        margin-top: 10px;
        text-transform: uppercase;
        transition: background 0.15s, border-color 0.15s;
    }

        .btn-agregar:hover {
            background: rgba(91,196,245,0.08);
            border-color: var(--aifa-glow);
        }

    .btn-guardar {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, var(--aifa-blue), var(--aifa-sky));
        border: 1px solid var(--aifa-glow);
        color: #fff;
        font-family: 'Rajdhani', sans-serif;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 3px;
        cursor: pointer;
        border-radius: 3px;
        text-transform: uppercase;
        transition: opacity 0.15s;
    }

        .btn-guardar:hover {
            opacity: 0.85;
        }

    #msg-ok {
        display: none;
        background: rgba(29,168,158,0.12);
        border: 1px solid rgba(29,168,158,0.4);
        color: var(--aifa-teal);
        padding: 8px 10px;
        margin-top: 8px;
        font-family: 'Share Tech Mono',monospace;
        font-size: 10px;
        letter-spacing: 1px;
        border-radius: 3px;
        text-align: center;
    }

    #msg-err {
        display: none;
        background: rgba(212,39,58,0.12);
        border: 1px solid rgba(212,39,58,0.4);
        color: #f07080;
        padding: 8px 10px;
        margin-top: 8px;
        font-family: 'Share Tech Mono',monospace;
        font-size: 10px;
        letter-spacing: 1px;
        border-radius: 3px;
        text-align: center;
    }
</style>

<!-- ═══════════════════════════════════════════════════ -->
<!-- HEADER AIFA                                         -->
<!-- ═══════════════════════════════════════════════════ -->
