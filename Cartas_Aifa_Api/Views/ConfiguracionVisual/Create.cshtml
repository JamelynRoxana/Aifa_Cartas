        <path d="M58 40 Q48 18 26 18 Q38 23 58 40Z" fill="#1da89e" opacity="0.70" />
        <path d="M58 40 Q50 14 30 12 Q42 19 58 40Z" fill="#1da89e" opacity="0.55" />
        <!-- Ala derecha -->
        <path d="M62 40 Q75 28 100 32 Q88 34 62 40Z" fill="#cc2438" opacity="0.95" />
        <path d="M62 40 Q78 30 102 36 Q90 37 62 40Z" fill="#999" opacity="0.7" />
        <path d="M62 40 Q76 26 104 30 Q92 31 62 40Z" fill="#999" opacity="0.5" />
        <path d="M62 40 Q74 22  98 24 Q86 27 62 40Z" fill="#1da89e" opacity="0.85" />
