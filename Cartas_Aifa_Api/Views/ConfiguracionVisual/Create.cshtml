    <div class="aifa-badge">CONFIG. VISUAL</div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- LAYOUT                                              -->
<!-- ═══════════════════════════════════════════════════ -->
<div class="row">

    <!-- ── LIENZO ── -->
    <div class="col-md-7">
        <div class="lienzo-label">Vista previa de carta</div>

        <div id="contenedor-hoja">
            <!-- Esquinas técnicas -->
            <div class="sheet-corner tl"></div>
            <div class="sheet-corner tr"></div>
            <div class="sheet-corner bl"></div>
            <div class="sheet-corner br"></div>

            <!-- Watermark -->
            <div class="watermark-area">
                <svg class="watermark-svg" width="90" height="60" viewBox="0 0 120 80">
                    <path d="M58 40 Q45 28 20 32 Q32 34 58 40Z" fill="#1e6fb5" />
                    <path d="M58 40 Q42 30 18 36 Q30 37 58 40Z" fill="#1e6fb5" />
                    <path d="M58 40 Q44 26 16 30 Q28 31 58 40Z" fill="#1e6fb5" />
                    <path d="M58 40 Q46 22 22 24 Q34 27 58 40Z" fill="#1e6fb5" />
                    <path d="M58 40 Q48 18 26 18 Q38 23 58 40Z" fill="#1e6fb5" />
                    <path d="M62 40 Q75 28 100 32 Q88 34 62 40Z" fill="#1e6fb5" />
                    <path d="M62 40 Q78 30 102 36 Q90 37 62 40Z" fill="#1e6fb5" />
                    <path d="M62 40 Q76 26 104 30 Q92 31 62 40Z" fill="#1e6fb5" />
                    <path d="M62 40 Q74 22  98 24 Q86 27 62 40Z" fill="#1e6fb5" />
                    <path d="M62 40 Q72 18  94 18 Q82 23 62 40Z" fill="#1e6fb5" />
                </svg>
                <div class="watermark-text">Área de carta</div>
                <div class="watermark-text" style="font-size:10px; letter-spacing:5px; margin-top:2px;">AIFA · SEDE CENTRAL</div>
            </div>

            <!-- Stripes de pista -->
            <div class="runway-stripe">
                <span></span><span></span><span></span><span></span><span></span>
            </div>
        </div>

        <div class="leyenda">
            <span><i class="dot dot-rojo"></i> Nuevo elemento</span>
            <span><i class="dot dot-gold"></i> Existente (editable)</span>
        </div>
    </div>

    <!-- ── PANEL ── -->
    <div class="col-md-5">
        <div class="panel-config">

            <!-- SECCIÓN 1: Contexto -->
            <div class="panel-section">
                <div class="panel-section-title">① Contexto de búsqueda</div>

                <div class="fgroup">
                    <label class="flabel">Año de aplicación</label>
                    <input type="number" class="form-control" id="f-anio" value="@DateTime.Now.Year" />
                </div>
                <div class="fgroup">
                    <label class="flabel">Mostrar en</label>
                    <select class="form-control" id="f-mostrarEn">
                        <option value="">-- Seleccione --</option>
                        <option value="Aceptacion">Aceptación</option>
                        <option value="Termino">Término</option>
                        <option value="Ambas">Ambas</option>
                    </select>
                </div>
                <div class="frow">
                    <div class="fgroup">
                        <label class="flabel">Fecha inicio</label>
                        <input type="date" class="form-control" id="f-inicio" />
                    </div>
                    <div class="fgroup">
                        <label class="flabel">Fecha fin</label>
                        <input type="date" class="form-control" id="f-fin" />
                    </div>
                </div>

                <div id="aviso-existentes">
                    ↳ <strong id="num-exist">0</strong> configuraciones cargadas — puedes reposicionarlas
                </div>
            </div>

            <!-- SECCIÓN 2: Agregar logo -->
            <div class="panel-section">
                <div class="panel-section-title red-dot">② Agregar nuevo logo</div>

                <div class="fgroup">
                    <label class="flabel">Logo del catálogo</label>
                    @Html.DropDownList("ImagenId", null, "-- Seleccione --",
                        new { @class = "form-control", id = "select-logo" })
                </div>
                <button type="button" class="btn-agregar" id="btn-agregar">+ Agregar al lienzo</button>
            </div>

            <!-- SECCIÓN 3: Lista elementos -->
            <div class="panel-section">
                <div class="panel-section-title gold-dot">Elementos en lienzo</div>

                <div id="lista-elementos">
                    <div style="padding:8px 0; font-family:'Share Tech Mono',monospace; font-size:10px; color:#506070; letter-spacing:1px;">
                        Sin elementos aún
                    </div>
                </div>

                <!-- Edición seleccionado -->
                <div id="panel-edicion">
                    <div style="margin-top:12px; padding-top:12px; border-top:1px solid rgba(255,255,255,0.06);">
                        <div class="panel-section-title" style="margin-bottom:10px;">Editar seleccionado</div>
                        <div class="frow" style="margin-bottom:8px;">
                            <div class="fgroup">
                                <label class="flabel">X (px)</label>
                                <input type="number" class="form-control" id="edit-x" readonly />
                            </div>
                            <div class="fgroup">
                                <label class="flabel">Y (px)</label>
                                <input type="number" class="form-control" id="edit-y" readonly />
                            </div>
                        </div>
                        <div class="frow">
                            <div class="fgroup">
                                <label class="flabel">Ancho</label>
                                <input type="number" class="form-control" id="edit-w" min="30" />
                            </div>
                            <div class="fgroup">
                                <label class="flabel">Alto</label>
                                <input type="number" class="form-control" id="edit-h" min="20" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 4: Guardar -->
            <div class="panel-section">
                <button type="button" class="btn-guardar" id="btn-guardar">Guardar todo</button>
                <div id="msg-ok">✓ Guardado correctamente</div>
                <div id="msg-err">✗ Error al guardar</div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script>
$(document).ready(function () {

    var elementos = [], counter = 0, selId = null;

    // ── Helpers ──────────────────────────────────────────
    function getElem(id) { return elementos.find(function(e){ return e.id===id; }); }

    function syncEdicion(id) {
        var e = getElem(id); if (!e) return;
        $("#edit-x").val(Math.round(e.x));
        $("#edit-y").val(Math.round(e.y));
        $("#edit-w").val(Math.round(e.w));
        $("#edit-h").val(Math.round(e.h));
    }

    function seleccionar(id) {
        selId = id;
        $(".elem-lienzo").removeClass("seleccionado");
        $(".item-lista").removeClass("activo");
        var e = getElem(id);
        if (!e) { $("#panel-edicion").hide(); return; }
        e.$el.addClass("seleccionado");
        $("#item-" + id).addClass("activo");
        syncEdicion(id);
        $("#panel-edicion").show();
    }

    function actualizarElem(id, x, y, w, h) {
        var e = getElem(id); if (!e) return;
        e.x=x; e.y=y; e.w=w; e.h=h;
        if (selId===id) syncEdicion(id);
    }

    // ── Crear elemento en lienzo ─────────────────────────
    function crearEnLienzo(elem) {
        var clsTipo = elem.tipo === 'nuevo' ? 'es-nuevo' : 'es-existente';
        var $el = $('<div class="elem-lienzo ' + clsTipo + '"></div>')
            .css({
                left: elem.x+"px", top: elem.y+"px",
                width: elem.w+"px", height: elem.h+"px",
                backgroundImage: "url('" + elem.url + "')"
            })
            .attr("data-id", elem.id);

        $el.append('<span class="lbl">' + elem.nombre + '</span>');
        elem.$el = $el;

        $el.draggable({
            containment: "#contenedor-hoja",
            stop: function(e, ui) {
                actualizarElem(elem.id, ui.position.left, ui.position.top,
                    $(this).width(), $(this).height());
            }
        }).resizable({
            containment: "#contenedor-hoja", handles: "all",
            stop: function(e, ui) {
                actualizarElem(elem.id, ui.position.left, ui.position.top,
                    ui.size.width, ui.size.height);
            }
        });

        $el.on("mousedown", function() { seleccionar(elem.id); });
        $("#contenedor-hoja").append($el);
        seleccionar(elem.id);
    }

    // ── Agregar a lista lateral ──────────────────────────
    function agregarALista(elem) {
        var tagClass  = elem.tipo === 'nuevo' ? 'tag-nuevo' : 'tag-exist';
        var tagLabel  = elem.tipo === 'nuevo' ? 'NEW'       : 'EXIST';
        var tipoClass = elem.tipo === 'nuevo' ? 'es-nuevo'  : 'es-existente';

        $("#lista-elementos > div:first-child").filter(function(){
            return $(this).find('.item-thumb').length === 0;
        }).remove();

        var $item = $(
            '<div class="item-lista ' + tipoClass + '" id="item-' + elem.id + '" data-id="' + elem.id + '">'
          + '<div class="item-thumb" style="background-image:url(\'' + elem.url + '\')"></div>'
          + '<span class="item-nombre">' + elem.nombre + '</span>'
          + '<span class="tag-tipo ' + tagClass + '">' + tagLabel + '</span>'
          + '</div>'
        );

        $item.on("click", function() { seleccionar(elem.id); });
        $("#lista-elementos").append($item);
    }

    // ── Cargar existentes ────────────────────────────────
    function limpiarExistentes() {
        elementos.filter(function(e){ return e.tipo==='existente'; })
                 .forEach(function(e){ e.$el.remove(); $("#item-"+e.id).remove(); });
        elementos = elementos.filter(function(e){ return e.tipo==='nuevo'; });
        if (elementos.length === 0)
            $("#lista-elementos").html('<div style="padding:8px 0;font-family:\'Share Tech Mono\',monospace;font-size:10px;color:#506070;letter-spacing:1px;">Sin elementos aún</div>');
        $("#aviso-existentes").hide();
    }

    function cargarExistentes() {
        var anio   = $("#f-anio").val(),
            mEn    = $("#f-mostrarEn").val(),
            inicio = $("#f-inicio").val(),
            fin    = $("#f-fin").val();

        limpiarExistentes();
        if (!anio || !mEn || !inicio || !fin) return;

        $.ajax({
            url: '@Url.Action("GetConfiguracionesExistentes", "ConfiguracionVisual")',
            type: 'GET',
            data: { anio: anio, mostrarEn: mEn, inicio: inicio, fin: fin },
            success: function(data) {
                if (!data || !data.length) return;
                $("#num-exist").text(data.length);
                $("#aviso-existentes").show();
                $.each(data, function(i, item) {
                    counter++;
                    var elem = {
                        id: counter, imagenId: item.imagenId || 0,
                        dbId: item.dbId || 0, url: item.url,
                        nombre: item.nombre || ('Elem ' + counter),
                        tipo: 'existente',
                        x: item.x, y: item.y, w: item.w, h: item.h, $el: null
                    };
                    elementos.push(elem);
                    crearEnLienzo(elem);
                    agregarALista(elem);
                });
            }
        });
    }

    $("#f-anio, #f-mostrarEn, #f-inicio, #f-fin").on("change", cargarExistentes);

    // ── Agregar nuevo logo ───────────────────────────────
    $("#btn-agregar").on("click", function() {
        var imagenId = $("#select-logo").val();
        var nombre   = $("#select-logo option:selected").text().trim();
        if (!imagenId) { alert("Selecciona un logo primero."); return; }
        if (!$("#f-inicio").val() || !$("#f-fin").val() || !$("#f-mostrarEn").val()) {
            alert("Completa primero el Año, Mostrar En y las fechas."); return;
        }

        $.ajax({
            url: '@Url.Action("GetImagenUrl", "ConfiguracionVisual")',
            type: 'GET',
            data: { id: imagenId },
            success: function(response) {
                if (response.url) {
                    counter++;
                    var elem = {
                        id: counter, imagenId: parseInt(imagenId),
                        dbId: 0, url: response.url, nombre: nombre,
                        tipo: 'nuevo', x: 10, y: 10, w: 150, h: 100, $el: null
                    };
                    elementos.push(elem);
                    crearEnLienzo(elem);
                    agregarALista(elem);
                }
            }
        });
    });

    // ── Edición manual de tamaño ─────────────────────────
    $("#edit-w, #edit-h").on("change", function() {
        if (!selId) return;
        var e = getElem(selId); if (!e) return;
        var w = parseInt($("#edit-w").val()) || e.w;
        var h = parseInt($("#edit-h").val()) || e.h;
        e.w=w; e.h=h;
        e.$el.css({ width: w+"px", height: h+"px" });
    });

    // ── Guardar todo ─────────────────────────────────────
    $("#btn-guardar").on("click", function() {
        if (!elementos.length) { alert("No hay elementos en el lienzo."); return; }
        var anio   = $("#f-anio").val(), mEn = $("#f-mostrarEn").val(),
            inicio = $("#f-inicio").val(), fin = $("#f-fin").val();
        if (!anio || !mEn || !inicio || !fin) {
            alert("Completa todos los campos de contexto antes de guardar."); return;
        }

        var nuevos = [], existentes = [];
        elementos.forEach(function(e) {
            var payload = {
                ImagenId: e.imagenId,
                CoordX: Math.round(e.x), CoordY: Math.round(e.y),
                Ancho:  Math.round(e.w), Alto:   Math.round(e.h),
                AnioAplicacion: parseInt(anio),
                MostrarEn: mEn, FechaInicio: inicio, FechaFin: fin
            };
            if (e.tipo === 'nuevo') {
                nuevos.push(payload);
            } else {
                payload.Id = e.dbId;
                existentes.push(payload);
            }
        });

        $.ajax({
            url: '@Url.Action("GuardarSesion", "ConfiguracionVisual")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ nuevos: nuevos, existentes: existentes }),
            success: function(r) {
                if (r.success) {
                    $("#msg-ok").show().delay(4000).fadeOut();
                    $("#msg-err").hide();
                } else {
                    $("#msg-err").text("✗ " + (r.message || "Error.")).show();
                }
            },
            error: function() { $("#msg-err").text("✗ Error de conexión.").show(); }
        });
    });
});
    </script>
}