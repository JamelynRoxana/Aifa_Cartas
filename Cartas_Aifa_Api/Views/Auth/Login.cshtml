@{
    Layout = null;
    ViewBag.Title = "Expediente Aero - Login";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

    <link href="@Url.Content("~/Content/tailwind.css")" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        .input-custom:focus {
            border-color: var(--color-celadon);
            box-shadow: 0 0 0 2px rgba(162, 227, 196, 0.2);
        }
    </style>

    <script>
        if (localStorage.getItem('jwt_token')) {
            window.location.replace('@Url.Action("Index", "Home")');
        }
    </script>
</head>
<body class="flex items-center justify-center min-h-screen p-4 overflow-hidden bg-gradient-to-r from-gray-50 to-gray-200 font-sans">

    <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-celadon/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-80 h-80 bg-base-blue/5 rounded-full blur-3xl"></div>

    <main class="w-full max-w-4xl grid md:grid-cols-2 bg-white/90 backdrop-blur-sm rounded-3xl shadow-[0_15px_40px_rgba(0,0,0,0.1)] overflow-hidden min-h-[550px] relative z-10 border border-white/50">

        <div class="hidden md:flex flex-col justify-between p-12 bg-base-blue text-white relative">
            <div class="relative z-10">
                <img src="@Url.Content("~/Assets/Imagenes/Logo-AIFA.png")" alt="Logo AIFA" class="h-12 mb-8 opacity-80 hover:opacity-100 transition-opacity" />
                <h1 class="text-4xl font-bold leading-tight drop-shadow-md">Gestión <br/><span class="text-celadon">Expediente Aero</span></h1>
                <p class="mt-4 text-ash-grey font-light max-w-xs text-sm leading-relaxed drop-shadow-sm">
                    Impulsando el talento que mueve nuestra terminal. Acceda para validar el progreso de los alumnos y emitir los documentos que avalan su trayectoria profesional.
                </p>
            </div>
            
            <div class="relative z-10 text-xs text-ash-grey/70 tracking-wide">
                &copy; <span id="currentYear"></span> AIFA - Sistema de Control Operativo
            </div>

            <div class="absolute bottom-0 right-0 p-4 opacity-[0.03] scale-150 origin-bottom-right">
                <i class="bi bi-shield-lock-fill text-9xl"></i>
            </div>
        </div>

        <div class="p-8 md:p-12 flex flex-col justify-center bg-white">
            <div class="flex justify-center mb-10 md:hidden">
                <img src="@Url.Content("~/Assets/Imagenes/Logo-AIFA.png")" alt="Logo AIFA" class="h-16 brightness-0 hover:scale-105 transition-transform" />
            </div>

            <div class="mb-10 text-center md:text-left">
                <h2 class="text-3xl md:text-2xl font-extrabold text-base-blue tracking-tight">Bienvenido de nuevo</h2>
                <p class="text-grey-olive text-sm mt-1">Por favor, introduce tus datos.</p>
            </div>

            <form id="loginForm" class="space-y-6">
                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-grey-olive mb-2 ml-1" for="correo">Correo Electrónico</label>
                    <div class="relative group shadow-sm rounded-xl">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ash-grey group-focus-within:text-base-blue transition-colors">
                            <i class="bi bi-envelope text-lg"></i>
                        </div>
                        <input type="email" id="correo" required 
                               class="w-full pl-12 pr-4 py-4 bg-gray-50/80 border border-gray-200 rounded-xl focus:bg-white focus:border-celadon focus:ring-4 focus:ring-celadon/20 transition-all outline-none text-sm text-base-blue placeholder-ash-grey font-medium" 
                               placeholder="nombre@aifa.com" />
                    </div>
                </div>

                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-grey-olive mb-2 ml-1" for="contrasena">Contraseña</label>
                    <div class="relative group shadow-sm rounded-xl">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ash-grey group-focus-within:text-base-blue transition-colors">
                            <i class="bi bi-shield-lock text-lg"></i>
                        </div>
                        <input type="password" id="contrasena" required 
                               class="w-full pl-12 pr-4 py-4 bg-gray-50/80 border border-gray-200 rounded-xl focus:bg-white focus:border-celadon focus:ring-4 focus:ring-celadon/20 transition-all outline-none text-sm text-base-blue font-medium" 
                               placeholder="••••••••" />
                    </div>
                </div>

                <div id="error-msg" class="hidden flex items-center p-4 text-red-700 rounded-xl bg-red-50 border border-red-100 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-octagon-fill mr-3 text-lg"></i>
                    <span class="text-sm font-semibold tracking-wide" id="error-text"></span>
                </div>

                <button type="submit" id="btn-submit" 
                        class="w-full bg-base-blue hover:bg-[#001730] text-white font-bold py-4 rounded-xl transition-all duration-300 shadow-[0_8px_20px_rgba(0,31,63,0.25)] hover:shadow-[0_12px_25px_rgba(0,31,63,0.35)] flex justify-center items-center group cursor-pointer active:scale-[0.98] mt-4">
                    <span id="btn-text" class="tracking-wide">Iniciar Sesión</span>
                    <i id="btn-icon" class="bi bi-arrow-right ml-3 text-lg group-hover:translate-x-2 transition-transform"></i>
                    <div id="btn-spinner" class="hidden animate-spin ml-3 w-5 h-5 border-2 border-r-transparent rounded-full border-celadon" role="status"></div>
                </button>
            </form>

            <div class="mt-8 pt-6 border-t border-gray-100 flex justify-center items-center">
                <a href="#" class="text-xs font-semibold tracking-wide text-grey-olive hover:text-base-blue transition-colors cursor-pointer border-b border-transparent hover:border-base-blue pb-0.5">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function () {
            // Set dynamic year
            $('#currentYear').text(new Date().getFullYear());

            $('#loginForm').submit(function (e) {
                e.preventDefault();

                // UI Feedback
                $('#error-msg').addClass('hidden');
                $('#btn-submit').prop('disabled', true).addClass('opacity-90 cursor-wait');
                $('#btn-text').text('Validando credenciales');
                $('#btn-icon').addClass('hidden');
                $('#btn-spinner').removeClass('hidden');

                var payload = {
                    Correo: $('#correo').val(),
                    Contrasena: $('#contrasena').val()
                };

                $.ajax({
                    url: '/api/auth/Login',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function (response) {
                        localStorage.setItem('jwt_token', response.token);
                        window.location.href = '@Url.Action("Index", "Home")';
                    },
                    error: function (xhr) {
                        var errMsg = "Error crítico de conexión.";
                        if (xhr.status === 401) errMsg = "Las credenciales no coinciden.";
                        else if (xhr.responseJSON && xhr.responseJSON.Message) errMsg = xhr.responseJSON.Message;

                        $('#error-text').text(errMsg);
                        $('#error-msg').removeClass('hidden');

                        // Restaurar UI
                        $('#btn-submit').prop('disabled', false).removeClass('opacity-90 cursor-wait');
                        $('#btn-text').text('Iniciar Sesión');
                        $('#btn-icon').removeClass('hidden');
                        $('#btn-spinner').addClass('hidden');
                    }
                });
            });
        });
    </script>
</body>
</html>