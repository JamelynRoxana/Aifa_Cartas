@{
    Layout = null;
    ViewBag.Title = "Iniciar Sesión - Terminal Digital";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

           <link href="@Url.Content("~/Content/tailwind.css")" rel="stylesheet" />
           <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
           <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

           <!-- Bloquear renderizado de la página de Login si ya existe un JWT -->
           <script>
               if (localStorage.getItem('jwt_token')) {
                   window.location.replace('@Url.Action("Index", "Home")');
               }
           </script>
       </head>
<body class="bg-gray-100 font-sans m-0 text-slate-800 flex h-screen items-center justify-center p-4">

    <div class="w-full max-w-md bg-white rounded-[25px] shadow-[0_10px_40px_rgba(0,0,0,0.08)] p-8 border border-white/30 relative">
        <div class="text-center mb-8">
            <img src="@Url.Content("~/Assets/Imagenes/Logo-AIFA.png")" alt="Logo AIFA" class="h-16 mx-auto mb-4 drop-shadow-sm" />
            <h2 class="text-2xl font-bold text-[#0c2f57]">Bienvenido al Sitema</h2>
            <p class="text-gray-500 text-sm mt-2">Ingrese sus credenciales para continuar</p>
        </div>

        <form id="loginForm" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1" for="correo">Correo Electrónico</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="bi bi-envelope text-gray-400"></i>
                    </div>
                    <input type="email" id="correo" required class="w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-[#00e5ff] focus:ring-1 focus:ring-[#00e5ff] transition-colors bg-gray-50/50" placeholder="admin@gmail.com" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1" for="contrasena">Contraseña</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="bi bi-lock text-gray-400"></i>
                    </div>
                    <input type="password" id="contrasena" required class="w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-[#00e5ff] focus:ring-1 focus:ring-[#00e5ff] transition-colors bg-gray-50/50" placeholder="••••••••" />
                </div>
            </div>

            <div id="error-msg" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative text-sm flex items-center shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill mr-2"></i>
                <span class="block sm:inline" id="error-text"></span>
            </div>

            <button type="submit" id="btn-submit" class="w-full bg-[#0c2f57] hover:bg-[#001f3f] text-white font-bold py-3 px-4 rounded-lg transition duration-300 shadow-md hover:shadow-lg flex justify-center items-center group">
                <span id="btn-text">Ingresar</span>
                <i id="btn-icon" class="bi bi-box-arrow-in-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                <div id="btn-spinner" class="hidden spinner-border animate-spin ml-2 w-4 h-4 border-2 rounded-full border-t-transparent border-white" role="status"></div>
            </button>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#loginForm').submit(function (e) {
                e.preventDefault();

                // Limpiar estado visual de errores y activar barra de carga
                $('#error-msg').addClass('hidden');
                $('#btn-submit').prop('disabled', true).addClass('opacity-80 cursor-not-allowed');
                $('#btn-text').text('Verificando...');
                $('#btn-icon').addClass('hidden');
                $('#btn-spinner').removeClass('hidden');

                var payload = {
                    Correo: $('#correo').val(),
                    Contrasena: $('#contrasena').val()
                };

                $.ajax({
                    url: '/api/auth/Login',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function (response) {
                        // Rescatamos el JSON Web Token de la respuesta
                        localStorage.setItem('jwt_token', response.token);

                        // Redireccionamiento inmediato al panel
                        window.location.href = '@Url.Action("Index", "Home")';
                    },
                    error: function (xhr) {
                        var errMsg = "Credenciales incorrectas o servidor no disponible.";
                        if (xhr.status === 401) {
                            errMsg = "Correo o contraseña incorrectos.";
                        } else if (xhr.responseJSON && xhr.responseJSON.Message) {
                            errMsg = xhr.responseJSON.Message;
                        }

                        $('#error-text').text(errMsg);
                        $('#error-msg').removeClass('hidden');

                        // Restaurar Boton
                        $('#btn-submit').prop('disabled', false).removeClass('opacity-80 cursor-not-allowed');
                        $('#btn-text').text('Ingresar');
                        $('#btn-icon').removeClass('hidden');
                        $('#btn-spinner').addClass('hidden');
                    }
                });
            });
        });
    </script>
</body>
</html>