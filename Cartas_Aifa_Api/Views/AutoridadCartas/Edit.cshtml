@model Cartas_Aifa_Api.Models.AutoridadAifa

@{
    ViewBag.Title = "Editar Autoridad";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-person-badge-fill me-2"></i>Editar Perfil de Autoridad
                </h4>
            </div>

            <div class="card-body p-5">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Id)

                    <div class="row g-4">
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="col-12">
                            <label class="form-label fw-bold text-primary">Nombre de la Autoridad</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control border-start-0", placeholder = "Ej. Gral. Isidro Pastor" } })
                            </div>
                            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-primary">Rango / Grado</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-award"></i></span>
                                @Html.EditorFor(model => model.Rango, new { htmlAttributes = new { @class = "form-control border-start-0", placeholder = "Ej. General de Brigada" } })
                            </div>
                            @Html.ValidationMessageFor(model => model.Rango, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-primary">Cargo en AIFA</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-briefcase"></i></span>
                                @Html.EditorFor(model => model.Puesto, new { htmlAttributes = new { @class = "form-control border-start-0", placeholder = "Ej. Director General" } })
                            </div>
                            @Html.ValidationMessageFor(model => model.Puesto, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-12 mt-5 d-flex justify-content-between">
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">
                                <i class="bi bi-check-circle me-2"></i>Actualizar Datos
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}