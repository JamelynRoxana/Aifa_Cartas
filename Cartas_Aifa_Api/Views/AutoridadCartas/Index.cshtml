@model IEnumerable<Cartas_Aifa_Api.Models.AutoridadAifa>

@{
    ViewBag.Title = "Catálogo de Autoridades";
}

<style>
    /* Contenedor principal translúcido */
    .glass-container {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        border-radius: 30px;
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    /* Estilo de tabla transparente */
    .table-glass {
        background: transparent !important;
        margin-bottom: 0;
    }

        .table-glass thead th {
            background: rgba(0, 31, 63, 0.8) !important; /* Azul marino translúcido */
            color: #fff;
            border: none;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
            padding: 20px;
        }

        .table-glass tbody tr {
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

            .table-glass tbody tr:hover {
                background: rgba(255, 255, 255, 0.4) !important;
                transform: scale(1.01);
            }

        .table-glass td {
            padding: 18px 20px !important;
            border: none;
        }

    /* Avatares modernos */
    .avatar-glass {
        background: var(--azul-electric);
        color: white;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(0, 116, 217, 0.3);
    }

    /* Botones de acción minimalistas */
    .action-link {
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.5);
        color: var(--azul-deep);
        margin: 0 3px;
        transition: all 0.2s;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .action-link:hover {
            background: var(--azul-deep);
            color: white !important;
            transform: translateY(-3px);
        }

    .btn-new {
        background: var(--azul-deep);
        color: white;
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-new:hover {
            background: var(--azul-electric);
            box-shadow: 0 5px 15px rgba(0, 116, 217, 0.4);
            color: white;
        }
</style>

<div class="animate__animated animate__fadeIn">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-white mb-0" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
                <i class="bi bi-shield-check me-2 text-info"></i>Personal Autorizado
            </h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="@Url.Action("Create")" class="btn-new shadow">
                <i class="bi bi-plus-lg me-2"></i>Registrar Oficial
            </a>
        </div>
    </div>

    <div class="glass-container">
        <div class="table-responsive">
            <table class="table table-glass align-middle">
                <thead>
                    <tr>
                        <th class="rounded-start-4">Oficial</th>
                        <th>Grado / Rango</th>
                        <th>Cargo Operativo</th>
                        <th class="text-center rounded-end-4">Gestión</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-glass me-3">
                                        @(item.Nombre.Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="fw-bold" style="color: #001f3f;">@Html.DisplayFor(modelItem => item.Nombre)</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-primary border px-3 py-2">
                                    <i class="bi bi-award-fill me-1"></i> @Html.DisplayFor(modelItem => item.Rango)
                                </span>
                            </td>
                            <td class="small text-muted fw-medium">
                                @Html.DisplayFor(modelItem => item.Puesto)
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="action-link text-primary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="@Url.Action("Details", new { id = item.Id })" class="action-link text-info" title="Ver Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="@Url.Action("Delete", new { id = item.Id })" class="action-link text-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cloud-slash fs-1 text-muted opacity-50"></i>
                <p class="mt-3 fw-bold text-muted">No se encontraron oficiales registrados en la base de datos.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Animación de entrada para las filas
        document.querySelectorAll('tbody tr').forEach((tr, index) => {
            tr.style.opacity = '0';
            tr.style.transform = 'translateY(10px)';
            setTimeout(() => {
                tr.style.transition = 'all 0.4s ease';
                tr.style.opacity = '1';
                tr.style.transform = 'translateY(0)';
            }, index * 100);
        });
    </script>
}