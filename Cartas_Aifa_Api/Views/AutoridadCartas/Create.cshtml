@model Cartas_Aifa_Api.Models.AutoridadAifa

@{
    ViewBag.Title = "Registro de Autoridad AIFA";
}

<style>
    /* Eliminamos el contenedor blanco y hacemos que el formulario se desvanezca */
    .form-wrapper-vortex {
        background: linear-gradient(to bottom, rgba(255,255,255,0.7) 0%, rgba(255,255,255,0.2) 100%);
        backdrop-filter: blur(8px); /* Desenfoque sutil del aeropuerto atrás */
        border-radius: 40px;
        padding: 60px;
        border: 1px solid rgba(255,255,255,0.3);
        max-width: 800px;
        margin: 0 auto;
        color: var(--azul-deep);
    }

    /* Campos de texto minimalistas (solo línea inferior) */
    .input-clean {
        background: transparent !important;
        border: none !important;
        border-bottom: 2px solid rgba(0, 31, 63, 0.2) !important;
        border-radius: 0 !important;
        padding: 15px 5px !important;
        font-size: 1.1rem !important;
        transition: all 0.4s ease;
        color: #001f3f !important;
    }

        .input-clean:focus {
            border-bottom: 2px solid var(--azul-electric) !important;
            box-shadow: none !important;
            background: rgba(255,255,255,0.1) !important;
        }

    /* Etiquetas voladoras */
    .label-float {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--azul-electric);
        margin-bottom: 0;
    }

    .btn-aero-glass {
        background: var(--azul-deep);
        color: white;
        border-radius: 50px;
        padding: 15px 40px;
        font-weight: 700;
        border: none;
        letter-spacing: 1px;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

        .btn-aero-glass:hover {
            background: var(--azul-electric);
            transform: scale(1.05);
            color: white;
        }

    /* Iconos que se desvanecen */
    .icon-fade {
        opacity: 0.6;
        font-size: 1.3rem;
        margin-right: 10px;
    }
</style>

<div class="animate__animated animate__fadeIn">
    <div class="form-wrapper-vortex">

        <div class="text-center mb-5">
            <i class="bi bi-shield-lock-fill fs-1 text-primary mb-3 d-block"></i>
            <h2 class="fw-bold">NUEVA AUTORIDAD</h2>
            <p class="text-muted small">CONTROL DE FIRMAS OPERATIVAS</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="row g-5">
                @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

                <div class="col-12">
                    <label class="label-float"><i class="bi bi-person icon-fade"></i>Nombre Completo</label>
                    @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control input-clean", placeholder = "Escriba el nombre del oficial..." } })
                    @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-6">
                    <label class="label-float"><i class="bi bi-award icon-fade"></i>Rango</label>
                    @Html.EditorFor(model => model.Rango, new { htmlAttributes = new { @class = "form-control input-clean", placeholder = "Ej. General" } })
                    @Html.ValidationMessageFor(model => model.Rango, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-6">
                    <label class="label-float"><i class="bi bi-briefcase icon-fade"></i>Puesto</label>
                    @Html.EditorFor(model => model.Puesto, new { htmlAttributes = new { @class = "form-control input-clean", placeholder = "Ej. Director" } })
                    @Html.ValidationMessageFor(model => model.Puesto, "", new { @class = "text-danger small" })
                </div>

                <div class="col-12 text-center mt-5">
                    <button type="submit" class="btn btn-aero-glass">
                        <i class="bi bi-check2-all me-2"></i>CONFIRMAR ALTA
                    </button>
                    <div class="mt-4">
                        <a href="@Url.Action("Index")" class="text-decoration-none text-muted small fw-bold">
                            CANCELAR Y VOLVER
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}