<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Terminal Digital</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --azul-deep: #001f3f;
            --azul-electric: #0074d9;
            --accent-sky: #00e5ff;
        }

        body {
            background-color: #f4f7f9;
            font-family: 'Inter', sans-serif;
            margin: 0;
        }

        /* --- HEADER CON IMAGEN --- */
        .hero-header {
            position: relative;
            height: 450px;
            width: 100%;
            background: linear-gradient(to bottom, rgba(0,31,63,0.4), rgba(244,247,249,1)),
                        url('https://i.imgur.com/5XhD8Hl.jpeg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            display: flex;
            flex-direction: column;
        }

        /* --- NAVBAR TRANSPARENTE --- */
        .navbar-custom {
            background: transparent;
            padding: 1.2rem 2rem;
            transition: all 0.4s ease;
        }

        .navbar-scrolled {
            background: rgba(0, 31, 63, 0.95) !important;
            backdrop-filter: blur(10px);
            padding: 0.6rem 2rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: #fff !important;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .nav-link {
            color: #fff !important;
            font-weight: 600;
            text-shadow: 0 1px 3px rgba(0,0,0,0.5);
            margin: 0 5px;
            border-radius: 8px;
            transition: 0.3s;
        }

        .nav-link:hover {
            background: rgba(255,255,255,0.15);
        }

        /* --- DROPDOWNS MEJORADOS --- */
        .dropdown-menu {
            border: none;
            border-top: 4px solid var(--accent-sky);
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            padding: 1rem;
            animation: slideUp 0.3s ease;
        }

        keyframes slideUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .dropdown-item {
            padding: 0.7rem 1.2rem;
            font-weight: 600;
            border-radius: 8px;
            display: flex;
            align-items: center;
            transition: 0.2s;
        }

        .dropdown-item:hover {
            background: #eef7ff;
            color: var(--azul-electric);
            transform: translateX(8px);
        }

        .dropdown-item i { margin-right: 12px; color: var(--azul-electric); }

        .main-content {
            margin-top: -100px;
            position: relative;
            z-index: 10;
            padding-bottom: 50px;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            border-radius: 25px;
            padding: 4rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            min-height: 600px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        footer {
            background: var(--azul-deep);
            color: rgba(255,255,255,0.6);
            padding: 3rem 0;
            margin-top: 50px;
        }
    </style>
</head>
<body>

    <header class="hero-header">
        <nav class="navbar navbar-expand-xl navbar-dark navbar-custom fixed-top" id="mainNav">
            <div class="container-fluid">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-airplane-engines-fill text-info me-2"></i>SISTEMA_PRO
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMenu">
                   
                    
                    @if (Request.IsAuthenticated)
                    {
                         <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-xl-5">

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Universidades</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("Create", "TramiteAcademico")"><i class="bi bi-passport"></i> Registro</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("Index", "TramiteAcademico")"><i class="bi bi-building"></i> Listado</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Estudiantes</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person-plus"></i> Registro</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-bar-chart-steps"></i> Etapa</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Aeropuerto</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-map"></i> Direcciones</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-diagram-3"></i> Subdirecciones</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-vector-pen"></i> Firma</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Imagenes</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-images"></i> Catalogo</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-sliders"></i> Configuracion</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Carta</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-layers-half"></i> Etapa</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-palette"></i> Carta</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Usuario</a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person-gear"></i> Administrar</a></li>
                            </ul>
                        </li>

                    </ul>

                        <form action="@Url.Action("Logout", "Account")" method="post" class="d-flex ms-xl-3 mt-3 mt-xl-0">
                            <button type="submit" class="btn btn-outline-light rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                            </button>
                        </form>
                    }
                    else
                    {
                       //codigo del nav sin auth
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="container-fluid main-content">
        <div class="row justify-content-center">
            <div class="col-11">
                <div class="glass-panel">
                    @RenderBody()
                </div>
            </div>
        </div>
    </main>

    <footer class="text-center">
        <p>&copy; @DateTime.Now.Year - Terminal Pro Aeropuerto Internacional</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(window).scroll(function () {
            if ($(this).scrollTop() > 50) {
                $('#mainNav').addClass('navbar-scrolled');
            } else {
                $('#mainNav').removeClass('navbar-scrolled');
            }
        });
    </script>

    @* --- ESTA LÍNEA DE AQUÍ ABAJO ES LA QUE SOLUCIONA EL ERROR --- *@
    @RenderSection("Scripts", required: false)

</body>
</html>