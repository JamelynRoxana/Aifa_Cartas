<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Terminal Digital</title>

    <link href="~/Content/tailwind.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Bloquear renderizado si no hay JWT -->
    <script>
        function checkAuth() {
            if (!localStorage.getItem('jwt_token') && window.location.pathname.toLowerCase().indexOf('/auth/login') === -1) {
                window.location.replace('@Url.Action("Login", "Auth")');
            }
        }
        checkAuth(); // Ejecuta al cargar 
        // Ejecuta al volver atrás o adelante en el navegador
        window.addEventListener('pageshow', function (event) {
            checkAuth();
        });
    </script>
</head>
<body class="bg-[#F4F6F8] font-sans m-0 text-slate-800">
    <nav id="mainNav" class="fixed top-0 w-full z-50 flex flex-wrap items-center justify-between px-6 py-4 xl:py-5 transition-all duration-400 ease-in-out text-white @(IsSectionDefined("Hero") ? "bg-transparent py-5" : "bg-[#001f3f]/95 backdrop-blur-md py-3 shadow-[0_4px_20px_rgba(0,0,0,0.2)]")">
        <div class="flex items-center justify-between w-full xl:w-auto">
            <a class="flex items-center transition-opacity hover:opacity-80 border-none outline-none" href="@Url.Action("Index", "Home")">
                <img src="~/Assets/Imagenes/Logo-AIFA.png" alt="Logo AIFA" class="h-10 md:h-12 xl:h-14 w-auto drop-shadow-md border-0 outline-none" />
            </a>
            <button id="navToggler" class="xl:hidden block text-white border border-white/30 px-3 py-1 bg-transparent rounded focus:outline-none transition" type="button">
                <i class="bi bi-list text-2xl"></i>
            </button>
        </div>

        <div id="navMenu" class="hidden w-full xl:flex xl:w-auto xl:items-center xl:ml-12 mt-4 xl:mt-0 xl:flex-1">
            @{
                var navMenus = new[]
                {
                    new {
                        Title = "Universidades",
                        IsRightAligned = false,
                        Items = new[] {
                            new { Text = "Registro", Icon = "bi-passport", Link = Url.Action("Create", "TramiteAcademico"), HtmlId = "" },
                            new { Text = "Listado", Icon = "bi-building", Link = Url.Action("Index", "TramiteAcademico"), HtmlId = "" }
                        }
                    },
                    new {
                        Title = "Estudiantes",
                        IsRightAligned = false,
                        Items = new[] {
                            new { Text = "Registro", Icon = "bi-person-plus", Link = "#", HtmlId = "" },
                            new { Text = "Etapa", Icon = "bi-bar-chart-steps", Link = "#", HtmlId = "" }
                        }
                    },
                    new {
                        Title = "Aeropuerto",
                        IsRightAligned = false,
                        Items = new[] {
                            new { Text = "Direcciones", Icon = "bi-map", Link = "#", HtmlId = "" },
                            new { Text = "Subdirecciones", Icon = "bi-diagram-3", Link = "#", HtmlId = "" },
                            new { Text = "Firma", Icon = "bi-vector-pen", Link = "#", HtmlId = "" }
                        }
                    },
                    new {
                        Title = "Imagenes",
                        IsRightAligned = false,
                        Items = new[] {
                            new { Text = "Catalogo", Icon = "bi-images", Link = "#", HtmlId = "" },
                            new { Text = "Configuracion", Icon = "bi-sliders", Link = "#", HtmlId = "" }
                        }
                    },
                    new {
                        Title = "Carta",
                        IsRightAligned = false,
                        Items = new[] {
                            new { Text = "Etapa", Icon = "bi-layers-half", Link = "#", HtmlId = "" },
                            new { Text = "Carta", Icon = "bi-palette", Link = "#", HtmlId = "" }
                        }
                    },
                    new {
                        Title = "Usuario",
                        IsRightAligned = true,
                        Items = new[] {
                            new { Text = "Administrar", Icon = "bi-person-gear", Link = "#", HtmlId = "" },
                            new { Text = "Cerrar sesión", Icon = "bi-box-arrow-right", Link = "javascript:void(0);", HtmlId = "btnLogout" }
                        }
                    }
                };
            }
            <ul class="flex flex-col xl:flex-row list-none p-0 m-0 w-full xl:w-auto xl:mr-auto xl:ml-5">
                @foreach (var menu in navMenus)
                {
                    <li class="relative group mx-1 mb-2 xl:mb-0 @(menu.IsRightAligned ? "xl:ml-auto" : "")">
                        <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>@menu.Title</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                        <ul class="nav-dropdown-menu hidden xl:absolute @(menu.IsRightAligned ? "right-0" : "left-0") top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                            @foreach (var item in menu.Items)
                            {
                                <li>
                                    <a id="@item.HtmlId" class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 @(item.HtmlId == "btnLogout" ? "hover:bg-red-50 hover:translate-x-0" : "hover:bg-[#eef7ff] hover:translate-x-2") text-gray-800" href="@item.Link">
                                        <i class="bi @item.Icon mr-3 @(item.HtmlId == "btnLogout" ? "text-red-500 font-bold" : "text-[#0074d9]")"></i> 
                                        <span class="@(item.HtmlId == "btnLogout" ? "text-red-600 font-bold" : "")">@item.Text</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        </div>
    </nav>

    @RenderSection("Hero", required: false)

    <main class="w-full relative z-10 pb-[50px] px-4 xl:px-12 flex justify-center @(IsSectionDefined("Hero") ? "-mt-[100px]" : "mt-[120px]")">
        <div class="w-full max-w-[1400px]">
            <div class="bg-white/90 backdrop-blur-sm rounded-[25px] p-6 sm:p-12 xl:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.08)] min-h-[600px] border border-white/30">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="text-center bg-[#001f3f] text-white/60 py-12 mt-12">
        <p>&copy; @DateTime.Now.Year - Terminal Pro Aeropuerto Internacional</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        // === SEGURIDAD Y JWT GLOBAL ===

        // Configuración Universal de AJAX para inyectar token JWT
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
                }
            }
        });

        // Interceptar TODOS los errores 401 no autorizados globalmente
        $(document).ajaxError(function (event, jqxhr, settings, thrownError) {
            if (jqxhr.status === 401 || jqxhr.status === 403) {
                // Eliminar token corrupto o vencido
                localStorage.removeItem('jwt_token');
                // Expulsar al usuario del sistema automáticamente
                window.location.href = '@Url.Action("Login", "Auth")';
            }
        });
        
        $(document).ready(function() {
            var hasHero = @(IsSectionDefined("Hero").ToString().ToLower());
            var isMenuExpanded = false;

            function updateNavbarStyle() {
                if ($(window).scrollTop() > 50 || !hasHero || isMenuExpanded) {
                    $('#mainNav')
                        .addClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]')
                        .removeClass('bg-transparent py-5');
                } else {
                    $('#mainNav')
                        .removeClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]')
                        .addClass('bg-transparent py-5');
                }
            }

            $('#navToggler').click(function() {
                $('#navMenu').slideToggle(300);
                isMenuExpanded = !isMenuExpanded;
                updateNavbarStyle();
            });

            $('.nav-dropdown-toggle').click(function(e) {
                if ($(window).width() < 1280) { // xl breakpoint
                    e.preventDefault();
                    var $menu = $(this).next('.nav-dropdown-menu');
                    var $icon = $(this).find('.bi-chevron-down');
                    
                    // Cierra los demás menús que estén abiertos
                    $('.nav-dropdown-menu').not($menu).slideUp(300);
                    $('.nav-dropdown-toggle .bi-chevron-down').not($icon).removeClass('rotate-180');
                    
                    // Alterna el menú actual
                    $menu.slideToggle(300);
                    $icon.toggleClass('rotate-180');
                }
            });

            $(window).scroll(function () {
                updateNavbarStyle();
            });

            // Evaluamos la condición inicial
            updateNavbarStyle();

            // Cerrar sesión
            $('#btnLogout').click(function (e) {
                e.preventDefault();
                localStorage.removeItem('jwt_token');
                window.location.href = '@Url.Action("Login", "Auth")';
            });
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>