<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Terminal Digital</title>

    <link href="~/Content/tailwind.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-[#F4F6F8] font-sans m-0 text-slate-800">
    <nav id="mainNav" class="fixed top-0 w-full z-50 flex flex-wrap items-center justify-between px-6 py-4 xl:py-5 transition-all duration-400 ease-in-out text-white @(IsSectionDefined("Hero") ? "bg-transparent py-5" : "bg-base-blue/95 backdrop-blur-md py-3 shadow-[0_4px_20px_rgba(0,0,0,0.2)]")">
        <div class="flex items-center justify-between w-full xl:w-auto">
            <a class="flex items-center transition-opacity hover:opacity-80 border-none outline-none" href="@Url.Action("Index", "Home")">
                <img src="~/Assets/Imagenes/Logo-AIFA.png" alt="Logo AIFA" class="h-10 md:h-12 xl:h-14 w-auto drop-shadow-md border-0 outline-none" />
            </a>
            <button id="navToggler" class="xl:hidden block text-white border border-white/30 px-3 py-1 bg-transparent rounded focus:outline-none transition" type="button">
                <i class="bi bi-list text-2xl"></i>
            </button>
        </div>

        <div id="navMenu" class="hidden w-full xl:flex xl:w-auto xl:items-center xl:ml-12 mt-4 xl:mt-0 xl:flex-1">
            <ul class="flex flex-col xl:flex-row list-none p-0 m-0 w-full xl:w-auto xl:mr-auto xl:ml-5">
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Universidades</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="@Url.Action("Create", "TramiteAcademico")"><i class="bi bi-passport text-[#0074d9] mr-3"></i> Registro</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="@Url.Action("Index", "TramiteAcademico")"><i class="bi bi-building text-[#0074d9] mr-3"></i> Listado</a></li>
                    </ul>
                </li>
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Estudiantes</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-person-plus text-[#0074d9] mr-3"></i> Registro</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-bar-chart-steps text-[#0074d9] mr-3"></i> Etapa</a></li>
                    </ul>
                </li>
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Aeropuerto</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-map text-[#0074d9] mr-3"></i> Direcciones</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-diagram-3 text-[#0074d9] mr-3"></i> Subdirecciones</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-vector-pen text-[#0074d9] mr-3"></i> Firma</a></li>
                    </ul>
                </li>
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Imagenes</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-images text-[#0074d9] mr-3"></i> Catalogo</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-sliders text-[#0074d9] mr-3"></i> Configuracion</a></li>
                    </ul>
                </li>
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Carta</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-layers-half text-[#0074d9] mr-3"></i> Etapa</a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-palette text-[#0074d9] mr-3"></i> Carta</a></li>
                    </ul>
                </li>
                <li class="relative group mx-1 mb-2 xl:mb-0 xl:ml-auto">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle"><span>Usuario</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i></a>
                    <ul class="nav-dropdown-menu hidden xl:absolute right-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-48 bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:block xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2 mt-2 xl:mt-5">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:text-[#0074d9] text-gray-800 hover:translate-x-2" href="#"><i class="bi bi-person-gear text-[#0074d9] mr-3"></i> Administrar</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    @RenderSection("Hero", required: false)

    <main class="w-full relative z-10 pb-[50px] px-4 xl:px-12 flex justify-center @(IsSectionDefined("Hero") ? "-mt-[100px]" : "mt-[120px]")">
        <div class="w-full max-w-[1400px]">
            <div class="bg-white/90 backdrop-blur-sm rounded-[25px] p-6 sm:p-12 xl:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.08)] min-h-[600px] border border-white/30">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="text-center bg-base-blue text-white/60 py-12 mt-12">
        <p>&copy; @DateTime.Now.Year - Terminal Pro Aeropuerto Internacional</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        $(document).ready(function() {
            var hasHero = @(IsSectionDefined("Hero").ToString().ToLower());
            var isMenuExpanded = false;

            function updateNavbarStyle() {
                if ($(window).scrollTop() > 50 || !hasHero || isMenuExpanded) {
                    $('#mainNav')
                        .addClass('bg-base-blue/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]')
                        .removeClass('bg-transparent py-5');
                } else {
                    $('#mainNav')
                        .removeClass('bg-base-blue/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]')
                        .addClass('bg-transparent py-5');
                }
            }

            $('#navToggler').click(function() {
                $('#navMenu').slideToggle(300);
                isMenuExpanded = !isMenuExpanded;
                updateNavbarStyle();
            });

            $('.nav-dropdown-toggle').click(function(e) {
                if ($(window).width() < 1280) { // xl breakpoint
                    e.preventDefault();
                    var $menu = $(this).next('.nav-dropdown-menu');
                    var $icon = $(this).find('.bi-chevron-down');
                    
                    // Cierra los demás menús que estén abiertos
                    $('.nav-dropdown-menu').not($menu).slideUp(300);
                    $('.nav-dropdown-toggle .bi-chevron-down').not($icon).removeClass('rotate-180');
                    
                    // Alterna el menú actual
                    $menu.slideToggle(300);
                    $icon.toggleClass('rotate-180');
                }
            });

            $(window).scroll(function () {
                updateNavbarStyle();
            });

            // Evaluamos la condición inicial
            updateNavbarStyle();
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>