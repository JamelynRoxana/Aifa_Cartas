@model IEnumerable<Cartas_Aifa_Api.Models.TramiteAcademico>
@{
    ViewBag.Title = "Panel de Control de Cartas";
}

<div class="row mb-4">
    <div class="col-12 text-center text-xl-start">
        <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-pdf-fill me-2"></i>Emisión de Cartas Académicas</h2>
        <p class="text-muted">Gestión de folios, alumnos y validación de firmas para el AIFA.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-3 h-100">
            <div class="card-body">
                <h5 class="fw-bold"><i class="bi bi-plus-circle-fill me-2"></i>Nuevo Trámite</h5>
                <p class="small opacity-75">Registre un nuevo folio para generar una carta de aceptación o término.</p>
                <a href="@Url.Action("Create", "TramiteAcademico")" class="btn btn-light btn-sm rounded-pill px-4 fw-bold">
                    Comenzar Registro
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
            <div class="card-body d-flex align-items-center justify-content-around text-center">
                <div>
                    <h4 class="fw-bold mb-0 text-primary">@DateTime.Now.ToString("dd/MM/yyyy")</h4>
                    <span class="text-muted small">Fecha de Impresión</span>
                </div>
                <div class="vr"></div>
                <div>
                    <h4 class="fw-bold mb-0 text-success">Activo</h4>
                    <span class="text-muted small">Servidor de PDF</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-task me-2"></i>Trámites Listos para PDF</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4">Folio</th>
                            <th>Estudiante</th>
                            <th>Etapa</th>
                            <th>Tipo de Carta</th>
                            <th class="text-center">Acción de PDF</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 fw-bold text-primary">@item.Folio</td>
                                    <td>@item.Estudiante.NombreCompleto</td>
                                    <td><span class="badge bg-info text-dark">@item.DetalleEtapa.TipoEtapa</span></td>
                                    <td>@item.TipoCarta.NombreCarta</td>
                                    <td class="text-center">
                                        <a href="@Url.Action("ImprimirCarta", "TramiteAcademico", new { id = item.Id })"
                                           class="btn btn-sm btn-danger rounded-pill px-3 shadow-sm"
                                           target="_blank">
                                            <i class="bi bi-file-pdf-fill me-1"></i> Generar PDF
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-3"></i>
                                    No hay trámites registrados para mostrar.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>