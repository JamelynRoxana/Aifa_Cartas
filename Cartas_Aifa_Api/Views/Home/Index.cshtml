@model IEnumerable<Cartas_Aifa_Api.Models.TramiteAcademico>
@{
    ViewBag.Title = "Panel de Control de Cartas";
}

@section Hero {
    <div class="relative w-full h-[450px] bg-cover bg-right md:bg-center bg-scroll md:bg-fixed flex flex-col z-0 rounded-b-xl shadow-lg" style="background-image: linear-gradient(to bottom, rgba(12,40,67,0.7) 0%, rgba(12,40,67,0) 30%, rgba(244,247,249,0) 75%, rgba(244,247,249,1) 100%), url('https://www.gob.mx/cms/uploads/image/file/731485/WhatsApp_Image_2022-06-30_at_1.16.11_PM__2_.jpeg');"></div>
}

<div class="flex flex-wrap mb-6">
    <div class="w-full text-center xl:text-left">
        <h2 class="font-bold text-blue-600 text-3xl mb-2"><i class="bi bi-file-earmark-pdf-fill mr-2"></i>Emisión de Cartas Académicas</h2>
        <p class="text-purple-500">Gestión de folios, alumnos y validación de firmas para el AIFA.</p>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    <div class="xl:col-span-1 md:col-span-1">
        <div class="bg-blue-600 text-white shadow-sm rounded-2xl p-4 h-full flex flex-col">
            <div class="flex-1 p-2">
                <h5 class="font-bold text-xl mb-2"><i class="bi bi-plus-circle-fill mr-2"></i>Nuevo Trámite</h5>
                <p class="text-sm opacity-75 mb-4">Registre un nuevo folio para generar una carta de aceptación o término.</p>
                <a href="@Url.Action("Create", "TramiteAcademico")" class="inline-block bg-white text-blue-600 hover:bg-gray-100 text-sm font-bold rounded-full px-6 py-2 transition-colors">
                    Comenzar Registro
                </a>
            </div>
        </div>
    </div>

    <div class="xl:col-span-2 md:col-span-1">
        <div class="bg-white shadow-sm rounded-2xl p-4 h-full flex flex-col">
            <div class="flex-1 flex items-center justify-around text-center p-2">
                <div>
                    <h4 class="font-bold text-blue-600 text-2xl mb-1">@DateTime.Now.ToString("dd/MM/yyyy")</h4>
                    <span class="text-gray-500 text-sm">Fecha de Impresión</span>
                </div>
                <div class="w-px bg-gray-300 mx-4 self-stretch"></div>
                <div>
                    <h4 class="font-bold text-green-600 text-2xl mb-1">Activo</h4>
                    <span class="text-gray-500 text-sm">Servidor de PDF</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="flex flex-wrap mt-12">
    <div class="w-full">
        <div class="bg-white shadow-sm rounded-2xl overflow-hidden">
            <div class="bg-white py-4 px-5">
                <h5 class="mb-0 font-bold text-gray-900 text-xl"><i class="bi bi-list-task mr-2"></i>Trámites Listos para PDF</h5>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left align-middle border-collapse">
                    <thead class="bg-gray-100 text-gray-900">
                        <tr>
                            <th class="px-6 py-3 font-bold">Folio</th>
                            <th class="px-4 py-3 font-bold">Estudiante</th>
                            <th class="px-4 py-3 font-bold">Etapa</th>
                            <th class="px-4 py-3 font-bold">Tipo de Carta</th>
                            <th class="px-4 py-3 font-bold text-center">Acción de PDF</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 font-bold text-blue-600">@item.Folio</td>
                                    <td class="px-4 py-4 text-gray-900">@item.Estudiante.NombreCompleto</td>
                                    <td class="px-4 py-4"><span class="inline-block px-2 py-1 text-xs font-bold rounded bg-cyan-400 text-gray-900">@item.DetalleEtapa.TipoEtapa</span></td>
                                    <td class="px-4 py-4 text-gray-900">@item.TipoCarta.NombreCarta</td>
                                    <td class="px-4 py-4 text-center">
                                        <a href="@Url.Action("ImprimirCarta", "TramiteAcademico", new { id = item.Id })"
                                           class="inline-block bg-red-600 text-white hover:bg-red-700 text-sm rounded-full px-5 py-2 shadow-sm transition-colors"
                                           target="_blank">
                                            <i class="bi bi-file-pdf-fill mr-1"></i> Generar PDF
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-12 text-gray-500">
                                    <i class="bi bi-search text-5xl block mb-4"></i>
                                    No hay trámites registrados para mostrar.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>