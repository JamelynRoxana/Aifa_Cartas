@{
    Layout = null;
    ViewData["Title"] = "Recuperar Contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f4f8;
            padding: 1rem;
        }
        .card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        }
        .card .icon-box { width: 56px; height: 56px; background: #eef7ff; border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
        .card .icon-box i { font-size: 1.5rem; color: #0074d9; }
        .card h2 { font-size: 1.4rem; font-weight: 800; color: #001f3f; margin-bottom: 0.4rem; }
        .card .subtitle { color: #6b7c93; font-size: 0.85rem; margin-bottom: 2rem; line-height: 1.5; }

        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7c93; margin-bottom: 0.5rem; }
        .form-group input {
            width: 100%;
            padding: 14px 16px;
            background: #f7f9fc;
            border: 1.5px solid #e8edf3;
            border-radius: 12px;
            color: #001f3f;
            font-size: 0.9rem;
            font-weight: 500;
            outline: none;
            transition: all 0.3s;
        }
        .form-group input:focus { border-color: #a2e3c4; background: #fff; box-shadow: 0 0 0 4px rgba(162,227,196,0.15); }
        .form-group input::placeholder { color: #b8c5d3; }

        .captcha-group { margin-bottom: 1.25rem; }
        .captcha-group label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7c93; margin-bottom: 0.5rem; }
        .captcha-row { display: flex; align-items: center; gap: 12px; }
        .captcha-image {
            background: linear-gradient(135deg, #e8edf3 0%, #f7f9fc 100%);
            border: 1.5px solid #e8edf3;
            border-radius: 12px;
            padding: 10px 16px;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 6px;
            color: #001f3f;
            font-family: 'Courier New', monospace;
            user-select: none;
            position: relative;
            overflow: hidden;
            min-width: 160px;
            text-align: center;
        }
        .captcha-image::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(0,31,63,0.15);
            transform: rotate(-3deg);
        }
        .captcha-image::after {
            content: '';
            position: absolute;
            top: 30%;
            left: 0;
            right: 0;
            height: 1px;
            background: rgba(0,31,63,0.1);
            transform: rotate(2deg);
        }
        .captcha-refresh {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            border: 1.5px solid #e8edf3;
            background: #f7f9fc;
            color: #6b7c93;
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .captcha-refresh:hover { background: #eef7ff; border-color: #a2e3c4; color: #001f3f; }
        .captcha-input {
            flex: 1;
            padding: 12px 14px;
            background: #f7f9fc;
            border: 1.5px solid #e8edf3;
            border-radius: 12px;
            color: #001f3f;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 3px;
            outline: none;
            transition: all 0.3s;
            text-transform: uppercase;
        }
        .captcha-input:focus { border-color: #a2e3c4; background: #fff; box-shadow: 0 0 0 4px rgba(162,227,196,0.15); }
        .captcha-input::placeholder { color: #b8c5d3; letter-spacing: 1px; font-weight: 400; }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #001f3f;
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 6px 16px rgba(0,31,63,0.2);
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-submit:hover { background: #001730; transform: translateY(-1px); }
        .btn-submit:disabled { opacity: 0.7; cursor: wait; }
        .btn-submit .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #a2e3c4; border-radius: 50%; animation: spin 0.6s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .msg-box { display: none; padding: 12px 16px; border-radius: 12px; margin-bottom: 1rem; align-items: center; gap: 10px; font-size: 0.82rem; font-weight: 600; }
        .msg-box.success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; }
        .msg-box.error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .msg-box.show { display: flex; }

        .back-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 1.5rem; font-size: 0.82rem; font-weight: 600; color: #6b7c93; text-decoration: none; transition: color 0.2s; }
        .back-link:hover { color: #001f3f; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-box"><i class="bi bi-envelope-paper"></i></div>
        <h2>Recuperar contraseña</h2>
        <p class="subtitle">Ingresa tu correo electrónico y te enviaremos una nueva contraseña temporal.</p>

        <div class="msg-box" id="msgBox">
            <i class="bi" id="msgIcon"></i>
            <span id="msgText"></span>
        </div>

        <form id="forgotForm">
            <div class="form-group">
                <label for="correo">Correo electrónico</label>
                <input type="email" id="correo" required placeholder="tu_correo@@gmail.com" />
            </div>

            <div class="captcha-group">
                <label>Código de verificación</label>
                <div class="captcha-row">
                    <div class="captcha-image" id="captchaDisplay"></div>
                    <button type="button" class="captcha-refresh" id="captchaRefresh" title="Generar nuevo código">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
                <input type="text" class="captcha-input" id="captchaInput" required placeholder="Escribe el código" maxlength="6" autocomplete="off" style="margin-top: 10px;" />
            </div>

            <button type="submit" class="btn-submit" id="btn-submit">
                <span id="btn-text">Enviar contraseña</span>
                <i class="bi bi-send" id="btn-icon"></i>
                <div class="spinner" id="btn-spinner"></div>
            </button>
        </form>

        <a href="/Auth/Login" class="back-link"><i class="bi bi-arrow-left"></i> Volver al login</a>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        var captchaCode = '';

        function generarCaptcha() {
            var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            captchaCode = '';
            for (var i = 0; i < 6; i++) {
                captchaCode += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            $('#captchaDisplay').text(captchaCode);
        }

        generarCaptcha();
        $('#captchaRefresh').click(function() { generarCaptcha(); $('#captchaInput').val(''); });

        $('#forgotForm').submit(function(e) {
            e.preventDefault();

            var inputCode = $('#captchaInput').val().toUpperCase().trim();
            if (inputCode !== captchaCode) {
                $('#msgIcon').attr('class', 'bi bi-exclamation-circle');
                $('#msgText').text('El código de verificación no coincide.');
                $('#msgBox').removeClass('success').addClass('show error');
                generarCaptcha();
                $('#captchaInput').val('');
                return;
            }

            $('#msgBox').removeClass('show success error');
            $('#btn-submit').prop('disabled', true);
            $('#btn-text').text('Enviando...');
            $('#btn-icon').hide();
            $('#btn-spinner').show();

            $.ajax({
                url: '/api/auth/ForgotPassword',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Correo: $('#correo').val() }),
                success: function(response) {
                    $('#msgIcon').attr('class', 'bi bi-check-circle');
                    $('#msgText').text(response.message || 'Se envió una nueva contraseña a tu correo.');
                    $('#msgBox').removeClass('error').addClass('show success');
                    $('#btn-text').text('Enviado ✓');
                    $('#btn-icon').hide();
                    $('#btn-spinner').hide();
                    $('#btn-submit').prop('disabled', true).css({'background':'#065f46','box-shadow':'none'});
                    generarCaptcha();
                    $('#captchaInput').val('');
                },
                error: function(xhr) {
                    var msg = 'Error al procesar la solicitud.';
                    if (xhr.responseJSON && xhr.responseJSON.message) msg = xhr.responseJSON.message;
                    $('#msgIcon').attr('class', 'bi bi-exclamation-circle');
                    $('#msgText').text(msg);
                    $('#msgBox').removeClass('success').addClass('show error');
                    $('#btn-submit').prop('disabled', false);
                    $('#btn-text').text('Enviar contraseña');
                    $('#btn-icon').show();
                    $('#btn-spinner').hide();
                    generarCaptcha();
                    $('#captchaInput').val('');
                }
            });
        });
    </script>
</body>
</html>
