@{
    Layout = null;
    ViewData["Title"] = "Cambiar Contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f4f8;
            padding: 1rem;
        }
        .card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        }
        .card .icon-box { width: 56px; height: 56px; background: #fef3c7; border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
        .card .icon-box i { font-size: 1.5rem; color: #d97706; }
        .card h2 { font-size: 1.4rem; font-weight: 800; color: #001f3f; margin-bottom: 0.4rem; }
        .card .subtitle { color: #6b7c93; font-size: 0.85rem; margin-bottom: 2rem; line-height: 1.5; }

        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7c93; margin-bottom: 0.5rem; }
        .form-group input {
            width: 100%;
            padding: 14px 16px;
            background: #f7f9fc;
            border: 1.5px solid #e8edf3;
            border-radius: 12px;
            color: #001f3f;
            font-size: 0.9rem;
            font-weight: 500;
            outline: none;
            transition: all 0.3s;
        }
        .form-group input:focus { border-color: #a2e3c4; background: #fff; box-shadow: 0 0 0 4px rgba(162,227,196,0.15); }
        .form-group input::placeholder { color: #b8c5d3; }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #001f3f;
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 6px 16px rgba(0,31,63,0.2);
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-submit:hover { background: #001730; transform: translateY(-1px); }
        .btn-submit:disabled { opacity: 0.7; cursor: wait; }
        .btn-submit .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #a2e3c4; border-radius: 50%; animation: spin 0.6s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .msg-box { display: none; padding: 12px 16px; border-radius: 12px; margin-bottom: 1rem; align-items: center; gap: 10px; font-size: 0.82rem; font-weight: 600; }
        .msg-box.success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; }
        .msg-box.error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .msg-box.show { display: flex; }

        .password-strength { height: 4px; border-radius: 2px; background: #e8edf3; margin-top: 8px; overflow: hidden; }
        .password-strength .bar { height: 100%; border-radius: 2px; transition: all 0.3s; width: 0%; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-box"><i class="bi bi-shield-lock"></i></div>
        <h2>Cambiar contraseña</h2>
        <p class="subtitle">Ingresaste con una contraseña temporal. Debes establecer una nueva contraseña para continuar.</p>

        <div class="msg-box" id="msgBox">
            <i class="bi" id="msgIcon"></i>
            <span id="msgText"></span>
        </div>

        <form id="changeForm">
            <div class="form-group">
                <label for="nueva">Nueva contraseña</label>
                <input type="password" id="nueva" required placeholder="Mínimo 6 caracteres" minlength="6" />
                <div class="password-strength"><div class="bar" id="strengthBar"></div></div>
            </div>

            <div class="form-group">
                <label for="confirmar">Confirmar contraseña</label>
                <input type="password" id="confirmar" required placeholder="Repite la contraseña" minlength="6" />
            </div>

            <button type="submit" class="btn-submit" id="btn-submit">
                <span id="btn-text">Guardar nueva contraseña</span>
                <i class="bi bi-check-lg" id="btn-icon"></i>
                <div class="spinner" id="btn-spinner"></div>
            </button>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        // Si no tiene token, mandarlo al login
        if (!localStorage.getItem('jwt_token')) {
            window.location.replace('/Auth/Login');
        }

        // Indicador de fortaleza de contraseña
        $('#nueva').on('input', function() {
            var len = $(this).val().length;
            var bar = $('#strengthBar');
            if (len === 0) { bar.css({width:'0%', background:'#e8edf3'}); }
            else if (len < 6) { bar.css({width:'30%', background:'#ef4444'}); }
            else if (len < 10) { bar.css({width:'60%', background:'#f59e0b'}); }
            else { bar.css({width:'100%', background:'#10b981'}); }
        });

        $('#changeForm').submit(function(e) {
            e.preventDefault();

            var nueva = $('#nueva').val();
            var confirmar = $('#confirmar').val();

            if (nueva !== confirmar) {
                $('#msgIcon').attr('class', 'bi bi-exclamation-circle');
                $('#msgText').text('Las contraseñas no coinciden.');
                $('#msgBox').removeClass('success').addClass('show error');
                return;
            }

            $('#msgBox').removeClass('show success error');
            $('#btn-submit').prop('disabled', true);
            $('#btn-text').text('Guardando...');
            $('#btn-icon').hide();
            $('#btn-spinner').show();

            $.ajax({
                url: '/api/auth/CambiarContrasena',
                type: 'POST',
                contentType: 'application/json',
                headers: { 'Authorization': 'Bearer ' + localStorage.getItem('jwt_token') },
                data: JSON.stringify({ NuevaContrasena: nueva }),
                success: function(response) {
                    $('#msgIcon').attr('class', 'bi bi-check-circle');
                    $('#msgText').text(response.message || 'Contraseña actualizada.');
                    $('#msgBox').removeClass('error').addClass('show success');
                    $('#btn-text').text('Guardado ✓');
                    $('#btn-spinner').hide();
                    $('#btn-submit').prop('disabled', true).css({'background':'#065f46'});
                    // Redirigir al inicio después de 2 segundos
                    setTimeout(function() { window.location.href = '/'; }, 2000);
                },
                error: function(xhr) {
                    var msg = 'Error al cambiar la contraseña.';
                    if (xhr.responseJSON && xhr.responseJSON.message) msg = xhr.responseJSON.message;
                    $('#msgIcon').attr('class', 'bi bi-exclamation-circle');
                    $('#msgText').text(msg);
                    $('#msgBox').removeClass('success').addClass('show error');
                    $('#btn-submit').prop('disabled', false);
                    $('#btn-text').text('Guardar nueva contraseña');
                    $('#btn-icon').show();
                    $('#btn-spinner').hide();
                }
            });
        });
    </script>
</body>
</html>
