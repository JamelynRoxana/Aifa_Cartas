@model EtapaAifa
@{
    ViewData["Title"] = "Eliminar Etapa AIFA";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-red-600 mb-2"><i class="bi bi-trash mr-2"></i>Eliminar Etapa AIFA</h2>
    <p class="text-gray-600 mb-6">¿Está seguro que desea eliminar esta etapa?</p>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 space-y-4">
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Tipo Etapa</span>
            <p class="text-lg text-gray-900 mt-1">@Model.DetalleEtapa?.TipoEtapa</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Estudiante</span>
            <p class="text-lg text-gray-900 mt-1">@Model.Estudiante?.NombreCompleto</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Fecha Inicio</span>
            <p class="text-lg text-gray-900 mt-1">@Model.FechaInicio.ToString("dd/MM/yyyy")</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Fecha Fin</span>
            <p class="text-lg text-gray-900 mt-1">@Model.FechaFin.ToString("dd/MM/yyyy")</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Estado</span>
            <p class="text-lg text-gray-900 mt-1">@(Model.Activa ? "Activa" : "Inactiva")</p>
        </div>
    </div>
    <form asp-action="Delete" method="post" class="flex items-center gap-4 mt-6">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-red-700 transition-colors shadow-sm">
            <i class="bi bi-trash mr-1"></i> Confirmar Eliminación
        </button>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
    </form>
</div>
