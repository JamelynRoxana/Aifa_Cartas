@model TramiteAcademico
@{
    ViewData["Title"] = "Detalles Trámite";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-info-circle mr-2"></i>Detalles del Trámite</h2>

    <div class="bg-gray-50 rounded-xl p-6 space-y-4">
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Folio</span>
            <p class="text-lg text-blue-600 font-bold mt-1">@Model.Folio</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Estudiante</span>
            <p class="text-lg text-gray-900 mt-1">@Model.Estudiante?.NombreCompleto</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Etapa</span>
            <p class="text-lg text-gray-900 mt-1">@Model.DetalleEtapa?.TipoEtapa</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Tipo de Carta</span>
            <p class="text-lg text-gray-900 mt-1">@Model.TipoCarta?.NombreCarta</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Autoridad</span>
            <p class="text-lg text-gray-900 mt-1">@Model.Autoridad?.Nombre</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Fecha de Registro</span>
            <p class="text-lg text-gray-900 mt-1">@Model.FechaRegistro.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    <div class="flex items-center gap-4 mt-6">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-[#001f3f] text-white px-5 py-2 rounded-xl font-bold hover:bg-[#001530] transition-colors text-sm">Editar</a>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Volver al listado</a>
    </div>
</div>
