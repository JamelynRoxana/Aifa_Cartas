@model IEnumerable<TramiteAcademico>
@{
    ViewData["Title"] = "Trámites Académicos";
}

<div class="flex flex-wrap items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-900"><i class="bi bi-file-earmark-text mr-2"></i>Trámites Académicos</h2>
    <a asp-action="Create" class="bg-blue-600 text-white px-5 py-2 rounded-full text-sm font-bold hover:bg-blue-700 transition-colors shadow-sm">
        <i class="bi bi-plus-circle mr-1"></i> Crear Nuevo
    </a>
</div>

<div class="overflow-x-visible rounded-xl border border-gray-200">
    <table class="w-full text-left border-collapse">
        <thead class="bg-gray-100">
            <tr>
                <th class="px-6 py-3 font-bold text-gray-900">Autoridad</th>
                <th class="px-4 py-3 font-bold text-gray-900">Etapa</th>
                <th class="px-4 py-3 font-bold text-gray-900">Estudiante</th>
                <th class="px-4 py-3 font-bold text-gray-900">Tipo Carta</th>
                <th class="px-4 py-3 font-bold text-gray-900">Folio</th>
                <th class="px-4 py-3 font-bold text-gray-900">Fecha</th>
                <th class="px-4 py-3 font-bold text-gray-900 text-center">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 text-gray-900">@item.Autoridad?.Nombre</td>
                        <td class="px-4 py-4 text-gray-600">@item.DetalleEtapa?.TipoEtapa</td>
                        <td class="px-4 py-4 text-gray-900">@item.Estudiante?.NombreCompleto</td>
                        <td class="px-4 py-4 text-gray-600">@item.TipoCarta?.NombreCarta</td>
                        <td class="px-4 py-4 font-bold text-blue-600">@item.Folio</td>
                        <td class="px-4 py-4 text-gray-600">@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td class="px-4 py-4 text-center">
                            <div class="relative inline-block">
                                <button class="p-2 rounded-full hover:bg-gray-100 transition-colors focus:outline-none actions-toggle">
                                    <i class="bi bi-three-dots-vertical text-gray-600 text-lg"></i>
                                </button>
                                <div class="absolute right-0 mt-1 w-40 bg-white border border-gray-200 rounded-xl shadow-xl z-[100] hidden actions-menu">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded-t-xl"><i class="bi bi-pencil mr-2 text-blue-500"></i>Editar</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50"><i class="bi bi-eye mr-2 text-gray-500"></i>Detalles</a>
                                    <button type="button" onclick="openDeleteModal('/@(ViewContext.RouteData.Values["controller"])/Delete/@item.Id')" class="flex items-center w-full px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-b-xl"><i class="bi bi-trash mr-2"></i>Eliminar</button>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-12 text-gray-500">
                        <i class="bi bi-inbox text-4xl block mb-3"></i>
                        No hay trámites registrados.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
