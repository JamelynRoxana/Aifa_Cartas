@model TramiteAcademico
@{
    ViewData["Title"] = "Editar Trámite";
}

<div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-pencil mr-2"></i>Editar Trámite Académico</h2>

    <form asp-action="Edit" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />

        <!-- Sección: Datos del trámite -->
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:16px;padding:1.5rem;">
            <h3 style="font-size:0.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1rem;">
                <i class="bi bi-file-earmark-text mr-1"></i> Datos del trámite
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Folio" class="block text-sm font-semibold text-gray-700 mb-2">Folio</label>
                    <input asp-for="Folio" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                    <span asp-validation-for="Folio" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="IdEstudiante" class="block text-sm font-semibold text-gray-700 mb-2">Estudiante</label>
                    <select asp-for="IdEstudiante" asp-items="@((SelectList)ViewBag.IdEstudiante)" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                        <option value="">-- Seleccionar --</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Sección: Configuración de carta -->
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:1.5rem;">
            <h3 style="font-size:0.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1rem;">
                <i class="bi bi-gear mr-1"></i> Configuración de carta
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label asp-for="IdDetalleEtapa" class="block text-sm font-semibold text-gray-700 mb-2">Detalle Etapa</label>
                    <select asp-for="IdDetalleEtapa" asp-items="@((SelectList)ViewBag.IdDetalleEtapa)" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                        <option value="">-- Seleccionar --</option>
                    </select>
                </div>
                <div>
                    <label asp-for="IdAut" class="block text-sm font-semibold text-gray-700 mb-2">Autoridad</label>
                    <select asp-for="IdAut" asp-items="@((SelectList)ViewBag.IdAut)" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                        <option value="">-- Seleccionar --</option>
                    </select>
                </div>
                <div>
                    <label asp-for="IdTipoCarta" class="block text-sm font-semibold text-gray-700 mb-2">Tipo de Carta</label>
                    <select asp-for="IdTipoCarta" asp-items="@((SelectList)ViewBag.IdTipoCarta)" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                        <option value="">-- Seleccionar --</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Sección: Fechas y horas -->
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:16px;padding:1.5rem;">
            <h3 style="font-size:0.8rem;font-weight:700;color:#166534;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1rem;">
                <i class="bi bi-calendar-range mr-1"></i> Fechas y horas
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                    <label asp-for="FechaRegistro" class="block text-sm font-semibold text-gray-700 mb-2">Fecha del documento</label>
                    <input asp-for="FechaRegistro" type="date" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
                <div>
                    <label asp-for="TotalHoras" class="block text-sm font-semibold text-gray-700 mb-2">Total de horas</label>
                    <input asp-for="TotalHoras" type="number" min="1" placeholder="200" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="FechaInicioPeriodo" class="block text-sm font-semibold text-gray-700 mb-2">Fecha inicio (periodo)</label>
                    <input asp-for="FechaInicioPeriodo" type="date" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
                <div>
                    <label asp-for="FechaFinPeriodo" class="block text-sm font-semibold text-gray-700 mb-2">Fecha fin (periodo)</label>
                    <input asp-for="FechaFinPeriodo" type="date" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
            </div>
        </div>

        <div class="flex items-center gap-4 pt-2">
            <button type="submit" style="background:#001f3f;color:#fff;padding:12px 28px;border-radius:12px;font-weight:700;border:none;cursor:pointer;font-size:0.9rem;display:inline-flex;align-items:center;gap:6px;box-shadow:0 2px 8px rgba(0,31,63,0.3);">
                <i class="bi bi-check-lg"></i> Guardar cambios
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
