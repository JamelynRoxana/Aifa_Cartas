@model ConfiguracionRegistro?
@{
    ViewData["Title"] = "Ventana de Registro";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-2"><i class="bi bi-calendar-range mr-2"></i>Ventana de Registro</h2>
    <p class="text-gray-500 mb-8">Define el período en que los estudiantes pueden registrar sus datos.</p>

    @if (Model != null && Model.Activo)
    {
        var ahora = DateTime.UtcNow;
        var habilitado = ahora >= Model.FechaInicio && ahora <= Model.FechaFin;
        var badgeClass = habilitado ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700";
        var badgeText = habilitado ? "Registro ABIERTO" : "Registro CERRADO";

        <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-8 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-gray-900">Configuración actual</h3>
                <span class="px-3 py-1 text-xs font-bold rounded-full @badgeClass">@badgeText</span>
            </div>
            <div class="flex" style="gap:2rem;">
                <div>
                    <p class="text-xs font-bold text-gray-400 uppercase mb-1">Desde</p>
                    <p class="text-gray-900 font-semibold">@Model.FechaInicio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-gray-400 uppercase mb-1">Hasta</p>
                    <p class="text-gray-900 font-semibold">@Model.FechaFin.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-8">
            <p class="text-yellow-800 text-sm font-semibold"><i class="bi bi-exclamation-triangle mr-2"></i>No hay una ventana de registro configurada. El formulario de estudiantes está cerrado.</p>
        </div>
    }

    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-gray-900 mb-4"><i class="bi bi-pencil mr-2"></i>Configurar nueva ventana</h3>
        <form asp-action="Guardar" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div class="flex gap-4 flex-wrap">
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Fecha y hora de inicio</label>
                    <input type="datetime-local" name="fechaInicio" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Fecha y hora de cierre</label>
                    <input type="datetime-local" name="fechaFin" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                </div>
            </div>
            <button type="submit" class="bg-[#001f3f] text-white px-6 py-3 rounded-xl font-bold hover:bg-[#001530] transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Guardar configuración
            </button>
        </form>
    </div>
</div>
