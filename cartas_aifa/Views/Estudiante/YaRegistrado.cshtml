@{
    ViewData["Title"] = "Ya Registrado";
}

<div class="max-w-lg mx-auto text-center py-12">
    <div class="mx-auto w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6">
        <i class="bi bi-check-circle-fill text-4xl text-green-600"></i>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-3">Ya estás registrado</h2>
    <p class="text-gray-500 mb-8">
        Tus datos ya fueron registrados exitosamente. Solo se permite un registro por estudiante.
    </p>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-blue-700 mb-6">
        <i class="bi bi-info-circle mr-2"></i>
        Si necesitas modificar tus datos, contacta al administrador.
    </div>

    <a href="/" class="inline-block bg-[#001f3f] text-white px-6 py-3 rounded-xl font-bold hover:bg-[#001530] transition-colors shadow-sm">
        <i class="bi bi-house mr-1"></i> Ir al inicio
    </a>
</div>
