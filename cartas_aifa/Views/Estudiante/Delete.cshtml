@model Estudiante
@{
    ViewData["Title"] = "Eliminar Estudiante";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-red-600 mb-2"><i class="bi bi-trash mr-2"></i>Eliminar Estudiante</h2>
    <p class="text-gray-600 mb-6">¿Está seguro que desea eliminar este estudiante?</p>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 space-y-4">
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Nombre</span>
            <p class="text-lg text-gray-900 mt-1">@Model.NombreCompleto</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Matrícula</span>
            <p class="text-lg text-gray-900 mt-1">@Model.Matricula</p>
        </div>
    </div>
    <form asp-action="Delete" method="post" class="flex items-center gap-4 mt-6">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-red-700 transition-colors shadow-sm">
            <i class="bi bi-trash mr-1"></i> Confirmar Eliminación
        </button>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
    </form>
</div>
