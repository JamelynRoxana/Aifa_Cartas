@model PiePagina
@{ ViewData["Title"] = "Detalles Pie de Página"; }
<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Detalles Pie de Página</h2>
    <div class="bg-gray-50 rounded-xl p-6 space-y-3">
        <div><span class="text-sm font-bold text-gray-500 uppercase">Texto</span><p class="text-gray-900 mt-1">@Model.Texto</p></div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Línea</span><p class="mt-1">@(Model.TieneLinea ? "Sí" : "No")</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Color</span><p class="mt-1"><span style="display:inline-block;width:20px;height:20px;border-radius:4px;background:@Model.ColorLinea;vertical-align:middle;"></span> @Model.ColorLinea</p></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Grosor</span><p class="mt-1">@Model.GrosorLinea pt</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Tamaño fuente</span><p class="mt-1">@Model.TamanoFuente pt</p></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Mostrar En</span><p class="mt-1">@Model.MostrarEn</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Alineación</span><p class="mt-1">@Model.Alineacion</p></div>
        </div>
    </div>
    <div class="flex items-center gap-4 mt-6">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-blue-600 text-white px-5 py-2 rounded-xl font-bold hover:bg-blue-700 text-sm">Editar</a>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Volver</a>
    </div>
</div>
