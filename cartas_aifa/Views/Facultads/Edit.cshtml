@model Facultad
@{
    ViewData["Title"] = "Editar Facultad";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-mortarboard mr-2"></i>Editar Facultad</h2>

    <form asp-action="Edit" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />

        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:16px;padding:1.5rem;">
            <h3 style="font-size:0.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1rem;">
                <i class="bi bi-mortarboard mr-1"></i> Información de la facultad
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="IdU" class="block text-sm font-semibold text-gray-700 mb-2">Universidad</label>
                    <select asp-for="IdU" asp-items="ViewBag.IdU" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                        <option value="">-- Seleccionar --</option>
                    </select>
                    <span asp-validation-for="IdU" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="NombreF" class="block text-sm font-semibold text-gray-700 mb-2">Nombre de Facultad</label>
                    <input asp-for="NombreF" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
                    <span asp-validation-for="NombreF" class="text-red-500 text-sm"></span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-4 pt-2">
            <button type="submit" style="background:#001f3f;color:#fff;padding:12px 24px;border-radius:12px;font-weight:700;border:none;cursor:pointer;font-size:0.9rem;display:inline-flex;align-items:center;gap:6px;box-shadow:0 2px 8px rgba(0,31,63,0.3);">
                <i class="bi bi-check-lg"></i> Guardar
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
