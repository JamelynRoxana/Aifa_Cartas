@model ImagenCatalogo
@{
    ViewData["Title"] = "Subir Imagen";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-images mr-2"></i>Subir Imagen al Catálogo</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <div>
            <label asp-for="NombreArchivo" class="block text-sm font-semibold text-gray-700 mb-2">Nombre descriptivo</label>
            <input asp-for="NombreArchivo" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="Ej: Logo Telegestion" />
            <span asp-validation-for="NombreArchivo" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Archivo de imagen</label>
            <input type="file" name="archivoImagen" accept="image/*"
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
            <p class="text-xs text-gray-400 mt-1">Formatos: JPG, PNG, GIF. Se guardará en el servidor.</p>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="bg-[#001f3f] text-white px-6 py-3 rounded-xl font-bold hover:bg-[#001530] transition-colors shadow-sm">
                <i class="bi bi-upload mr-1"></i> Subir Imagen
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
