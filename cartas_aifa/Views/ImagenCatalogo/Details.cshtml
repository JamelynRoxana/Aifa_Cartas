@model ImagenCatalogo
@{
    ViewData["Title"] = "Detalles de Imagen";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-info-circle mr-2"></i>Detalles de la Imagen</h2>
    <div class="bg-gray-50 rounded-xl p-6 space-y-4">
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Nombre del Archivo</span>
            <p class="text-lg text-gray-900 mt-1">@Model.NombreArchivo</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">URL de Imagen</span>
            <p class="text-lg text-gray-900 mt-1 break-all">@Model.UrlImagen</p>
        </div>
        <div>
            <span class="text-sm font-bold text-gray-500 uppercase tracking-wide">Fecha de Carga</span>
            <p class="text-lg text-gray-900 mt-1">@Model.FechaCarga.ToString("dd/MM/yyyy")</p>
        </div>
    </div>
    <div class="flex items-center gap-4 mt-6">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-blue-600 text-white px-5 py-2 rounded-xl font-bold hover:bg-blue-700 transition-colors text-sm">Editar</a>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Volver al listado</a>
    </div>
</div>
