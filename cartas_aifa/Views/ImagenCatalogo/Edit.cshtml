@model ImagenCatalogo
@{
    ViewData["Title"] = "Editar Imagen";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-pencil mr-2"></i>Editar Imagen</h2>

    <form asp-action="Edit" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="NombreArchivo" class="block text-sm font-semibold text-gray-700 mb-2">Nombre del Archivo</label>
            <input asp-for="NombreArchivo" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="NombreArchivo" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="UrlImagen" class="block text-sm font-semibold text-gray-700 mb-2">URL de Imagen</label>
            <input asp-for="UrlImagen" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="UrlImagen" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="FechaCarga" class="block text-sm font-semibold text-gray-700 mb-2">Fecha de Carga</label>
            <input asp-for="FechaCarga" type="date" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="FechaCarga" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Guardar
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
