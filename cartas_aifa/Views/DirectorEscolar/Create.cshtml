@model DirectorEscolar
@{
    ViewData["Title"] = "Crear Director Escolar";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-person-badge mr-2"></i>Crear Director Escolar</h2>

    <form asp-action="Create" method="post" class="space-y-6">
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Universidad</label>
            <select id="selectUniversidad" asp-items="ViewBag.Universidades" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                <option value="">-- Seleccionar Universidad --</option>
            </select>
        </div>

        <div>
            <label asp-for="IdF" class="block text-sm font-semibold text-gray-700 mb-2">Facultad</label>
            <select asp-for="IdF" id="selectFacultad" asp-items="ViewBag.IdF" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                <option value="">-- Seleccionar Facultad --</option>
            </select>
            <span asp-validation-for="IdF" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Nombre" class="block text-sm font-semibold text-gray-700 mb-2">Nombre</label>
            <input asp-for="Nombre" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="Nombre del director" />
            <span asp-validation-for="Nombre" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Rango" class="block text-sm font-semibold text-gray-700 mb-2">Rango</label>
            <select asp-for="Rango" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                <option value="">-- Seleccionar --</option>
                <option value="Dr.">Dr.</option>
                <option value="Dra.">Dra.</option>
                <option value="Mtro.">Mtro.</option>
                <option value="Mtra.">Mtra.</option>
                <option value="Lic.">Lic.</option>
                <option value="Ing.">Ing.</option>
                <option value="C.P.">C.P.</option>
                <option value="Arq.">Arq.</option>
                <option value="L.A.E.">L.A.E.</option>
            </select>
            <span asp-validation-for="Rango" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Puesto" class="block text-sm font-semibold text-gray-700 mb-2">Puesto</label>
            <input asp-for="Puesto" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="Puesto" />
            <span asp-validation-for="Puesto" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Guardar
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    document.getElementById('selectUniversidad').addEventListener('change', function () {
        const idUniversidad = this.value;
        const selectFacultad = document.getElementById('selectFacultad');

        // Limpiar facultades
        selectFacultad.innerHTML = '<option value="">-- Seleccionar Facultad --</option>';

        if (!idUniversidad) return;

        fetch(`/DirectorEscolar/GetFacultadesPorUniversidad?idUniversidad=${idUniversidad}`)
            .then(response => response.json())
            .then(data => {
                data.forEach(function (facultad) {
                    const option = document.createElement('option');
                    option.value = facultad.id;
                    option.textContent = facultad.nombreF;
                    selectFacultad.appendChild(option);
                });
            });
    });
</script>
}
