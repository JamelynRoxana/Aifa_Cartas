@model Usuario
@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-person-plus mr-2"></i>Crear Usuario</h2>

    <form asp-action="Create" method="post" class="space-y-6" id="formUsuario">
        <div>
            <label asp-for="Nombre" class="block text-sm font-semibold text-gray-700 mb-2">Nombre</label>
            <input asp-for="Nombre" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="Nombre completo" />
            <span asp-validation-for="Nombre" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Correo" class="block text-sm font-semibold text-gray-700 mb-2">Correo</label>
            <div class="flex">
                <input type="text" id="correoUsuario" class="flex-1 px-4 py-3 border border-gray-200 rounded-l-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="usuario" />
                <span class="px-4 py-3 bg-gray-100 border border-l-0 border-gray-200 rounded-r-xl text-gray-600 font-semibold flex items-center">@@gmail.com</span>
            </div>
            <input type="hidden" asp-for="Correo" id="correoCompleto" />
            <span asp-validation-for="Correo" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Contrasena" class="block text-sm font-semibold text-gray-700 mb-2">Contraseña</label>
            <input asp-for="Contrasena" type="password" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="Contraseña" />
            <span asp-validation-for="Contrasena" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Rol" class="block text-sm font-semibold text-gray-700 mb-2">Rol</label>
            <select asp-for="Rol" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all">
                <option value="">-- Seleccionar rol --</option>
                <option value="Administrativo">Administrativo</option>
                <option value="Estudiante">Estudiante</option>
                <option value="Directivo">Directivo</option>
            </select>
            <span asp-validation-for="Rol" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="bg-[#001f3f] text-white px-6 py-3 rounded-xl font-bold hover:bg-[#001530] transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Guardar
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    document.getElementById('formUsuario').addEventListener('submit', function() {
        var usuario = document.getElementById('correoUsuario').value.trim();
        document.getElementById('correoCompleto').value = usuario + '@@gmail.com';
    });
</script>
}
