@model Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-pencil mr-2"></i>Editar Usuario</h2>

    <form asp-action="Edit" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="Nombre" class="block text-sm font-semibold text-gray-700 mb-2">Nombre</label>
            <input asp-for="Nombre" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="Nombre" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Correo" class="block text-sm font-semibold text-gray-700 mb-2">Correo</label>
            <input asp-for="Correo" type="email" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="Correo" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Contrasena" class="block text-sm font-semibold text-gray-700 mb-2">Contraseña <span class="text-gray-400 text-xs font-normal">(dejar vacío para no cambiarla)</span></label>
            <input asp-for="Contrasena" type="password" value="" autocomplete="new-password" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" placeholder="••••••••" />
        </div>

        <div>
            <label asp-for="Rol" class="block text-sm font-semibold text-gray-700 mb-2">Rol</label>
            <input asp-for="Rol" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all" />
            <span asp-validation-for="Rol" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Guardar
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
