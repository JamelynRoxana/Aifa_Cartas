@model Carrera
@{
    ViewData["Title"] = "Eliminar Carrera";
}

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-red-600 mb-6"><i class="bi bi-trash mr-2"></i>Eliminar Carrera</h2>

    <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
        <p class="text-gray-700 mb-4">¿Estás seguro de eliminar esta carrera?</p>
        <div class="space-y-2">
            <div><span class="font-semibold">Carrera:</span> @Model.NombreCarrera</div>
            <div><span class="font-semibold">Facultad:</span> @Model.Facultad?.NombreF</div>
            <div><span class="font-semibold">Universidad:</span> @Model.Facultad?.Universidad?.NombreU</div>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="flex items-center gap-4">
            <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-red-700 transition-colors shadow-sm">
                <i class="bi bi-trash mr-1"></i> Confirmar Eliminación
            </button>
            <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Cancelar</a>
        </div>
    </form>
</div>
