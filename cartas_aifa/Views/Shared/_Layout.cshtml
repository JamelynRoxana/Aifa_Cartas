    @RenderSection("Hero", required: false)

    <main class="w-full relative z-10 pb-[50px] px-4 xl:px-12 flex justify-center @(IsSectionDefined("Hero") ? "-mt-[100px]" : "mt-[120px]")">
        <div class="w-full max-w-[1400px]">
            <div class="bg-white/90 backdrop-blur-sm rounded-[25px] p-6 sm:p-12 xl:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.08)] min-h-[600px] border border-white/30">
                @RenderBody()
            </div>
        </div>
    </main>

    <!-- Modal de confirmación de eliminación -->
    <div id="deleteModal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999;">
        <div id="deleteModalOverlay" style="position:absolute; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(4px);"></div>
        <div style="position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; padding:1rem;">
            <div style="position:relative; background:white; border-radius:1rem; box-shadow:0 25px 50px rgba(0,0,0,0.25); width:100%; max-width:380px;">
                <div class="p-6 text-center">
                    <div class="mx-auto w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mb-4">
                        <i class="bi bi-trash text-2xl text-red-600"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">¿Eliminar registro?</h3>
                    <p class="text-gray-500 text-sm mb-6">Esta acción no se puede deshacer.</p>
                    <form id="deleteForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full py-3 rounded-xl font-bold text-white bg-red-600 hover:bg-red-700 transition-colors shadow-sm mb-3">
                            <i class="bi bi-trash mr-1"></i> Eliminar
                        </button>
                    </form>
                    <button type="button" id="deleteCancelBtn" class="w-full py-3 rounded-xl font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center bg-[#001f3f] text-white/60 py-12 mt-12">
        <p>&copy; @DateTime.Now.Year - Terminal Pro Aeropuerto Internacional</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) { xhr.setRequestHeader('Authorization', 'Bearer ' + token); }
            }
        });
        $(document).ajaxError(function (event, jqxhr) {
            if (jqxhr.status === 401 || jqxhr.status === 403) {
                localStorage.removeItem('jwt_token');
                window.location.href = '/Auth/Login';
            }
        });
        $(document).ready(function() {
            var hasHero = @(IsSectionDefined("Hero").ToString().ToLower());
            var isMenuExpanded = false;
            function updateNavbarStyle() {
                if ($(window).scrollTop() > 50 || !hasHero || isMenuExpanded) {
                    $('#mainNav').addClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]').removeClass('bg-transparent py-5');
                } else {
                    $('#mainNav').removeClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]').addClass('bg-transparent py-5');
                }
            }
            $('#navToggler').click(function() { $('#navMenu').slideToggle(300); isMenuExpanded = !isMenuExpanded; updateNavbarStyle(); });
            $('.nav-dropdown-toggle').click(function(e) {
                if ($(window).width() < 1280) {
                    e.preventDefault();
                    var $menu = $(this).next('.nav-dropdown-menu'), $icon = $(this).find('.bi-chevron-down');
                    $('.nav-dropdown-menu').not($menu).slideUp(300);
                    $('.nav-dropdown-toggle .bi-chevron-down').not($icon).removeClass('rotate-180');
                    $menu.slideToggle(300); $icon.toggleClass('rotate-180');
                }
            });
            $(window).scroll(function () { updateNavbarStyle(); });
            updateNavbarStyle();
            $('#btnLogout').click(function (e) { e.preventDefault(); localStorage.removeItem('jwt_token'); localStorage.removeItem('user_name'); window.location.href = '/Auth/Login'; });
            // Mostrar nombre en navbar
            var navName = localStorage.getItem('user_name');
            if (navName) { $('#navUserName').text(navName.split(' ')[0]); }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Dropdown de acciones (tres puntos)
        document.addEventListener('click', function(e) {
            var toggle = e.target.closest('.actions-toggle');
            var allMenus = document.querySelectorAll('.actions-menu');
            if (toggle) {
                e.stopPropagation();
                var menu = toggle.nextElementSibling;
                var isOpen = !menu.classList.contains('hidden');
                allMenus.forEach(function(m) { m.classList.add('hidden'); });
                if (!isOpen) menu.classList.remove('hidden');
            } else {
                allMenus.forEach(function(m) { m.classList.add('hidden'); });
            }
        });

        // Modal de eliminación
        function openDeleteModal(url) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteModal').style.display = 'block';
        }
        document.getElementById('deleteCancelBtn').addEventListener('click', function() {
            document.getElementById('deleteModal').style.display = 'none';
        });
        document.getElementById('deleteModalOverlay').addEventListener('click', function() {
            document.getElementById('deleteModal').style.display = 'none';
        });
    </script>
</body>
</html>
