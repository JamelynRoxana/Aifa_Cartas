                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span>Aeropuerto</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/DireccionAifa"><i class="bi bi-map mr-3 text-[#0074d9]"></i><span>Direcciones</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/SubdireccionAifa"><i class="bi bi-diagram-3 mr-3 text-[#0074d9]"></i><span>Subdirecciones</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/AutoridadCartas"><i class="bi bi-vector-pen mr-3 text-[#0074d9]"></i><span>Autoridades</span></a></li>
                    </ul>
                </li>
                <!-- Cartas -->
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span>Cartas</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/DetalleEtapa"><i class="bi bi-layers-half mr-3 text-[#0074d9]"></i><span>Catálogo Etapas</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/DetallesTipoCarta"><i class="bi bi-file-earmark-text mr-3 text-[#0074d9]"></i><span>Tipos de Carta</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/Leyenda"><i class="bi bi-blockquote-left mr-3 text-[#0074d9]"></i><span>Leyendas</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/PiePagina"><i class="bi bi-text-paragraph mr-3 text-[#0074d9]"></i><span>Pie de Página</span></a></li>
                    </ul>
                </li>
                <!-- Configuración -->
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span>Config</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/ImagenCatalogo"><i class="bi bi-images mr-3 text-[#0074d9]"></i><span>Catálogo Imágenes</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/ConfiguracionVisual"><i class="bi bi-sliders mr-3 text-[#0074d9]"></i><span>Config. Visual</span></a></li>
                    </ul>
                </li>
                <!-- Usuario (alineado a la derecha) -->
                <li class="relative group mx-1 mb-2 xl:mb-0 xl:ml-auto">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span><i class="bi bi-person-circle mr-1"></i> <span id="navUserName">Usuario</span></span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute right-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/Usuario"><i class="bi bi-person-gear mr-3 text-[#0074d9]"></i><span>Administrar</span></a></li>
