<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Terminal Digital</title>

    <link href="~/css/tailwind.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <script>
        function checkAuth() {
            if (!localStorage.getItem('jwt_token') && window.location.pathname.toLowerCase().indexOf('/auth/login') === -1) {
                window.location.replace('/Auth/Login');
            }
        }
        checkAuth();
        window.addEventListener('pageshow', function (event) { checkAuth(); });
    </script>
</head>
<body class="bg-[#F4F6F8] font-sans m-0 text-slate-800">
    <nav id="mainNav" class="fixed top-0 w-full z-50 flex flex-wrap items-center justify-between px-6 py-4 xl:py-5 transition-all duration-400 ease-in-out text-white @(IsSectionDefined("Hero") ? "bg-transparent py-5" : "bg-[#001f3f]/95 backdrop-blur-md py-3 shadow-[0_4px_20px_rgba(0,0,0,0.2)]")">
        <div class="flex items-center justify-between w-full xl:w-auto">
            <a class="flex items-center transition-opacity hover:opacity-80 border-none outline-none" href="/">
                <img src="~/images/Logo-AIFA.png" alt="Logo AIFA" class="h-10 md:h-12 xl:h-14 w-auto drop-shadow-md border-0 outline-none" />
            </a>
            <button id="navToggler" class="xl:hidden block text-white border border-white/30 px-3 py-1 bg-transparent rounded focus:outline-none transition" type="button">
