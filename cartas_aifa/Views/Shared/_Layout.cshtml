                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span>Trámites</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/TramiteAcademico/Create"><i class="bi bi-plus-circle mr-3 text-[#0074d9]"></i><span>Nuevo Trámite</span></a></li>
                        <li><a class="flex items-center px-4 py-2 font-semibold rounded-lg transition-transform duration-200 hover:bg-[#eef7ff] hover:translate-x-2 text-gray-800" href="/TramiteAcademico"><i class="bi bi-list-task mr-3 text-[#0074d9]"></i><span>Listado</span></a></li>
                    </ul>
                </li>
                <!-- Estudiantes -->
                <li class="relative group mx-1 mb-2 xl:mb-0">
                    <a class="py-2 px-3 font-semibold drop-shadow text-white hover:bg-white/15 rounded-lg transition duration-300 flex items-center justify-between cursor-pointer xl:pb-4 xl:-mb-4 relative z-10 nav-dropdown-toggle">
                        <span>Estudiantes</span> <i class="bi bi-chevron-down ml-1 xl:ml-3 text-xs transition-transform duration-300 xl:group-hover:rotate-180"></i>
                    </a>
                    <ul class="nav-dropdown-menu hidden xl:absolute left-0 top-full xl:mt-5 before:absolute before:-top-6 before:left-0 before:w-full before:h-6 before:content-[''] w-full xl:w-auto xl:min-w-[12rem] bg-white border-t-4 border-[#0c2f57] rounded-xl shadow-[0_15px_35px_rgba(0,0,0,0.2)] p-3 list-none z-50 xl:invisible xl:opacity-0 xl:translate-y-2 xl:group-hover:flex xl:group-hover:visible xl:group-hover:opacity-100 xl:group-hover:translate-y-0 transition-all duration-300 flex-col gap-1 xl:pt-2">
