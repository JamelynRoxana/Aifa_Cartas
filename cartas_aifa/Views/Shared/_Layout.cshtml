<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Terminal Digital</title>

    <link href="~/css/tailwind.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        input[type="text"]:not([data-no-capitalize]),
        input:not([type]):not([data-no-capitalize]) {
            text-transform: capitalize;
        }
        /* Responsive global */
        .overflow-x-visible { overflow-x: auto; }
        table { min-width: 600px; }
        @@media (max-width: 768px) {
            .max-w-5xl, .max-w-4xl, .max-w-3xl, .max-w-2xl { max-width: 100% !important; }
            .grid-cols-1.md\:grid-cols-2, .grid-cols-1.md\:grid-cols-3 { grid-template-columns: 1fr !important; }
            .hidden-mobile { display: none !important; }
            table { min-width: auto; font-size: 0.8rem; }
            table th, table td { padding: 8px 6px !important; }
            .flex-wrap { flex-wrap: wrap; }
        }
        @@media (max-width: 640px) {
            main { padding-left: 0.5rem !important; padding-right: 0.5rem !important; }
            main > div > div { padding: 1rem !important; border-radius: 16px !important; }
        }
        .actions-menu { padding: 8px !important; min-width: 160px !important; z-index: 9999 !important; position: absolute !important; }
        .actions-menu a, .actions-menu button { padding: 10px 14px !important; margin-bottom: 2px; }
        .overflow-x-visible { overflow: visible !important; }
        table { position: relative; }
        tbody { overflow: visible !important; }
        .rounded-xl.border { overflow: visible !important; }
        [style*="overflow-x:auto"] { overflow: visible !important; }
        [style*="overflow:visible"] { overflow: visible !important; }
        .relative.inline-block { position: relative; z-index: 100; }
    </style>

    <script>
        // Auto Title Case en inputs de texto al perder foco
        document.addEventListener('focusout', function(e) {
            var el = e.target;
            if (el.tagName === 'INPUT' && (el.type === 'text' || el.type === '') && !el.hasAttribute('data-no-capitalize') && !el.id.includes('filtro') && !el.id.includes('buscar') && !el.id.includes('Buscar') && !el.classList.contains('input-folio') && !el.classList.contains('captcha-input')) {
                el.value = el.value.toLowerCase().replace(/(?:^|\s)\S/g, function(a) { return a.toUpperCase(); });
            }
        });
    </script>
    <script>
        function checkAuth() {
            if (!localStorage.getItem('jwt_token') && window.location.pathname.toLowerCase().indexOf('/auth/login') === -1) {
                window.location.replace('/Auth/Login');
            }
        }
        checkAuth();
        window.addEventListener('pageshow', function (event) { checkAuth(); });
    </script>
</head>
