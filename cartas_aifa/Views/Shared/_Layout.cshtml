    @RenderSection("Hero", required: false)

    <main class="w-full relative z-10 pb-[50px] px-4 xl:px-12 flex justify-center @(IsSectionDefined("Hero") ? "-mt-[100px]" : "mt-[120px]")" style="flex:1;">
        <div class="w-full max-w-[1400px]">
            <div class="bg-white/90 backdrop-blur-sm rounded-[25px] p-6 sm:p-12 xl:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.08)] min-h-[600px] border border-white/30">
                @if (TempData["Exito"] != null)
                {
                    <div class="alerta-global" style="background:#f0fdf4;border:1px solid #86efac;border-radius:12px;padding:14px 18px;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="width:32px;height:32px;background:#dcfce7;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1rem;"></i>
                            </div>
                            <span style="color:#166534;font-weight:600;font-size:0.9rem;">@TempData["Exito"]</span>
                        </div>
                        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#16a34a;font-size:1.2rem;padding:4px;"><i class="bi bi-x-lg"></i></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alerta-global" style="background:#fef2f2;border:1px solid #fca5a5;border-radius:12px;padding:14px 18px;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="width:32px;height:32px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-exclamation-circle-fill" style="color:#dc2626;font-size:1rem;"></i>
                            </div>
                            <span style="color:#991b1b;font-weight:600;font-size:0.9rem;">@TempData["Error"]</span>
                        </div>
                        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#dc2626;font-size:1.2rem;padding:4px;"><i class="bi bi-x-lg"></i></button>
                    </div>
                }
                @if (TempData["Info"] != null)
                {
                    <div class="alerta-global" style="background:#eff6ff;border:1px solid #93c5fd;border-radius:12px;padding:14px 18px;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="width:32px;height:32px;background:#dbeafe;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-info-circle-fill" style="color:#2563eb;font-size:1rem;"></i>
                            </div>
                            <span style="color:#1e40af;font-weight:600;font-size:0.9rem;">@TempData["Info"]</span>
                        </div>
                        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#2563eb;font-size:1.2rem;padding:4px;"><i class="bi bi-x-lg"></i></button>
                    </div>
                }
                @if (TempData["Advertencia"] != null)
                {
                    <div class="alerta-global" style="background:#fffbeb;border:1px solid #fcd34d;border-radius:12px;padding:14px 18px;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="width:32px;height:32px;background:#fef3c7;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-exclamation-triangle-fill" style="color:#d97706;font-size:1rem;"></i>
                            </div>
                            <span style="color:#92400e;font-weight:600;font-size:0.9rem;">@TempData["Advertencia"]</span>
                        </div>
                        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#d97706;font-size:1.2rem;padding:4px;"><i class="bi bi-x-lg"></i></button>
                    </div>
                }
                <script>
                    setTimeout(function() {
                        document.querySelectorAll('.alerta-global').forEach(function(el) {
                            el.style.transition = 'opacity 0.4s, transform 0.4s';
                            el.style.opacity = '0';
                            el.style.transform = 'translateY(-10px)';
                            setTimeout(function() { el.remove(); }, 400);
                        });
                    }, 2000);
                </script>
                @RenderBody()
            </div>
        </div>
    </main>

    <!-- Modal de confirmación de eliminación -->
    <div id="deleteModal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999;">
        <div id="deleteModalOverlay" style="position:absolute; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(4px);"></div>
        <div style="position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; padding:1rem;">
            <div style="position:relative; background:white; border-radius:1rem; box-shadow:0 25px 50px rgba(0,0,0,0.25); width:100%; max-width:380px;">
                <div class="p-6 text-center">
                    <div class="mx-auto w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mb-4">
                        <i class="bi bi-trash text-2xl text-red-600"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">¿Eliminar registro?</h3>
                    <p class="text-gray-500 text-sm mb-6">Esta acción no se puede deshacer.</p>
                    <form id="deleteForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" id="deleteConfirmBtn" disabled class="w-full py-3 rounded-xl font-bold text-white bg-red-600 transition-colors shadow-sm mb-3" style="opacity:0.4;cursor:not-allowed;">
                            <i class="bi bi-trash mr-1"></i> <span id="deleteCountdown">Eliminar (10)</span>
                        </button>
                    </form>
                    <button type="button" id="deleteCancelBtn" class="w-full py-3 rounded-xl font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center bg-[#001f3f] text-white/60 py-12" style="margin-top:auto;">
        <p>&copy; @DateTime.Now.Year - Terminal Pro Aeropuerto Internacional</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) { xhr.setRequestHeader('Authorization', 'Bearer ' + token); }
            }
        });
        $(document).ajaxError(function (event, jqxhr) {
            if (jqxhr.status === 401 || jqxhr.status === 403) {
                localStorage.removeItem('jwt_token');
                window.location.href = '/Auth/Login';
            }
        });
        $(document).ready(function() {
            var hasHero = @(IsSectionDefined("Hero").ToString().ToLower());
            var isMenuExpanded = false;
            function updateNavbarStyle() {
                if ($(window).scrollTop() > 50 || !hasHero || isMenuExpanded) {
                    $('#mainNav').addClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]').removeClass('bg-transparent py-5');
                } else {
                    $('#mainNav').removeClass('bg-[#001f3f]/95 backdrop-blur-md !py-2 shadow-[0_4px_20px_rgba(0,0,0,0.2)]').addClass('bg-transparent py-5');
                }
            }
            $('#navToggler').click(function() { $('#navMenu').slideToggle(300); isMenuExpanded = !isMenuExpanded; updateNavbarStyle(); });
            $('.nav-dropdown-toggle').click(function(e) {
                if ($(window).width() < 1280) {
                    e.preventDefault();
                    var $menu = $(this).next('.nav-dropdown-menu'), $icon = $(this).find('.bi-chevron-down');
                    $('.nav-dropdown-menu').not($menu).slideUp(300);
                    $('.nav-dropdown-toggle .bi-chevron-down').not($icon).removeClass('rotate-180');
                    $menu.slideToggle(300); $icon.toggleClass('rotate-180');
                }
            });
            $(window).scroll(function () { updateNavbarStyle(); });
            updateNavbarStyle();
            $('#btnLogout').click(function (e) { e.preventDefault(); localStorage.removeItem('jwt_token'); localStorage.removeItem('user_name'); localStorage.removeItem('user_rol'); window.location.href = '/Auth/Login'; });
            // Mostrar nombre en navbar
            var navName = localStorage.getItem('user_name');
            if (navName) {
                var formatted = navName.toLowerCase().replace(/(?:^|\s)\S/g, function(a) { return a.toUpperCase(); });
                $('#navUserName').text(formatted);
            }

            // Mostrar avatar en navbar
            var navAvatarUrl = localStorage.getItem('user_avatar');
            if (navAvatarUrl) {
                document.getElementById('navAvatar').src = navAvatarUrl;
                document.getElementById('navAvatar').style.display = 'inline-block';
                document.getElementById('navAvatarIcon').style.display = 'none';
            }

            // Reloj en tiempo real
            function actualizarReloj() {
                var ahora = new Date();
                var h = ahora.getHours().toString().padStart(2, '0');
                var m = ahora.getMinutes().toString().padStart(2, '0');
                var s = ahora.getSeconds().toString().padStart(2, '0');
                document.getElementById('navClock').textContent = h + ':' + m + ':' + s;
            }
            actualizarReloj();
            setInterval(actualizarReloj, 1000);
            document.getElementById('navClockBox').style.display = 'flex';

            // Control de visibilidad por rol
            var userRol = localStorage.getItem('user_rol') || '';
            $('[data-roles]').each(function() {
                var rolesPermitidos = $(this).attr('data-roles').split(',');
                if (rolesPermitidos.indexOf(userRol) === -1) {
                    $(this).hide();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Dropdown de acciones (tres puntos)
        document.addEventListener('click', function(e) {
            var toggle = e.target.closest('.actions-toggle');
            var allMenus = document.querySelectorAll('.actions-menu');
            if (toggle) {
                e.stopPropagation();
                var menu = toggle.nextElementSibling;
                var isOpen = !menu.classList.contains('hidden');
                allMenus.forEach(function(m) { m.classList.add('hidden'); });
                if (!isOpen) menu.classList.remove('hidden');
            } else {
                allMenus.forEach(function(m) { m.classList.add('hidden'); });
            }
        });

        // Modal de eliminación con temporizador
        var deleteTimer = null;
        function openDeleteModal(url) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteModal').style.display = 'block';
            
            // Deshabilitar botón e iniciar cuenta regresiva
            var btn = document.getElementById('deleteConfirmBtn');
            var countdown = document.getElementById('deleteCountdown');
            var segundos = 10;
            btn.disabled = true;
            btn.style.opacity = '0.4';
            btn.style.cursor = 'not-allowed';
            countdown.textContent = 'Eliminar (' + segundos + ')';
            
            if (deleteTimer) clearInterval(deleteTimer);
            deleteTimer = setInterval(function() {
                segundos--;
                if (segundos <= 0) {
                    clearInterval(deleteTimer);
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.style.cursor = 'pointer';
                    countdown.textContent = 'Eliminar';
                } else {
                    countdown.textContent = 'Eliminar (' + segundos + ')';
                }
            }, 1000);
        }
        document.getElementById('deleteCancelBtn').addEventListener('click', function() {
            document.getElementById('deleteModal').style.display = 'none';
            if (deleteTimer) clearInterval(deleteTimer);
        });
        document.getElementById('deleteModalOverlay').addEventListener('click', function() {
            document.getElementById('deleteModal').style.display = 'none';
            if (deleteTimer) clearInterval(deleteTimer);
        });
    </script>

    <!-- Modal de alerta personalizado -->
    <div id="alertModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:20px;padding:2rem;max-width:400px;width:90%;text-align:center;box-shadow:0 25px 50px rgba(0,0,0,0.25);animation:alertIn 0.2s ease;">
            <div id="alertIconBox" style="width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"></div>
            <h3 id="alertTitle" style="font-size:1.1rem;font-weight:800;color:#0f172a;margin-bottom:0.5rem;"></h3>
            <p id="alertMessage" style="color:#64748b;font-size:0.9rem;margin-bottom:1.5rem;line-height:1.5;"></p>
            <button id="alertAcceptBtn" onclick="cerrarAlerta()" style="width:100%;padding:12px;background:#001f3f;border:none;border-radius:12px;color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 2px 8px rgba(0,31,63,0.3);">
                Aceptar
            </button>
        </div>
    </div>
    <style>
        @@keyframes alertIn { from { opacity:0; transform:scale(0.9); } to { opacity:1; transform:scale(1); } }
        @@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }
    </style>
    <script>
        function mostrarAlerta(mensaje, tipo) {
            tipo = tipo || 'info';
            var modal = document.getElementById('alertModal');
            var iconBox = document.getElementById('alertIconBox');
            var title = document.getElementById('alertTitle');
            var msg = document.getElementById('alertMessage');
            var btn = document.getElementById('alertAcceptBtn');

            if (tipo === 'error') {
                iconBox.style.background = '#fee2e2';
                iconBox.innerHTML = '<i class="bi bi-exclamation-circle-fill" style="color:#dc2626;font-size:1.5rem;"></i>';
                title.textContent = '¡Atención!';
                btn.style.background = '#dc2626';
            } else if (tipo === 'exito') {
                iconBox.style.background = '#dcfce7';
                iconBox.innerHTML = '<i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1.5rem;"></i>';
                title.textContent = '¡Listo!';
                btn.style.background = '#16a34a';
            } else if (tipo === 'advertencia') {
                iconBox.style.background = '#fef3c7';
                iconBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill" style="color:#d97706;font-size:1.5rem;"></i>';
                title.textContent = 'Advertencia';
                btn.style.background = '#d97706';
            } else {
                iconBox.style.background = '#dbeafe';
                iconBox.innerHTML = '<i class="bi bi-info-circle-fill" style="color:#2563eb;font-size:1.5rem;"></i>';
                title.textContent = 'Información';
                btn.style.background = '#2563eb';
            }
            msg.textContent = mensaje;
            modal.style.display = 'flex';
        }
        function cerrarAlerta() {
            document.getElementById('alertModal').style.display = 'none';
        }
        document.getElementById('alertModal').addEventListener('click', function(e) {
            if (e.target === this) cerrarAlerta();
        });
        // Override native alert
        window.alert = function(msg) { mostrarAlerta(msg, 'advertencia'); };

        // Validar que Fecha Inicio < Fecha Fin en todos los formularios
        document.addEventListener('submit', function(e) {
            var form = e.target;
            var inicio = form.querySelector('input[name="FechaInicio"], input[name="FechaInicioPeriodo"]');
            var fin = form.querySelector('input[name="FechaFin"], input[name="FechaFinPeriodo"]');
            if (inicio && fin && inicio.value && fin.value) {
                if (new Date(inicio.value) >= new Date(fin.value)) {
                    e.preventDefault();
                    mostrarAlerta('La fecha de inicio debe ser anterior a la fecha de fin.', 'error');
                }
            }
        });
    </script>
</body>
</html>
