@model Leyenda
@{ ViewData["Title"] = "Detalles de Leyenda"; }

<div class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-blockquote-left mr-2"></i>Detalles de Leyenda</h2>
    <div class="bg-gray-50 rounded-xl p-6 space-y-4">
        <div><span class="text-sm font-bold text-gray-500 uppercase">Texto</span><p class="text-gray-900 mt-1 whitespace-pre-line">@Model.Texto</p></div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Alineación</span><p class="text-gray-900 mt-1">@Model.Alineacion</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Estilo</span><p class="text-gray-900 mt-1">@Model.EstiloFuente</p></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Tamaño</span><p class="text-gray-900 mt-1">@Model.TamanoFuente pt</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Mostrar En</span><p class="text-gray-900 mt-1">@Model.MostrarEn</p></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Coord X</span><p class="text-gray-900 mt-1">@Model.CoordX%</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Coord Y</span><p class="text-gray-900 mt-1">@Model.CoordY%</p></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div><span class="text-sm font-bold text-gray-500 uppercase">Fecha Inicio</span><p class="text-gray-900 mt-1">@Model.FechaInicio.ToString("dd/MM/yyyy")</p></div>
            <div><span class="text-sm font-bold text-gray-500 uppercase">Fecha Fin</span><p class="text-gray-900 mt-1">@Model.FechaFin.ToString("dd/MM/yyyy")</p></div>
        </div>
    </div>
    <div class="flex items-center gap-4 mt-6">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-blue-600 text-white px-5 py-2 rounded-xl font-bold hover:bg-blue-700 transition-colors text-sm">Editar</a>
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-semibold">Volver</a>
    </div>
</div>
